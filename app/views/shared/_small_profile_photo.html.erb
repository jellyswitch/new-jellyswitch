<div style="height: 50px; width: 50px;">

<%- if user.has_profile_photo? %>
  <%- if user.admin? %>
    <%= image_tag user.small_square_profile_photo, class: "rounded-circle border border-success" %>
  <%- else %>
    <%= image_tag user.small_square_profile_photo, class: "rounded-circle" %>
  <%- end %>
<%- else %>
  <%= image_tag "profile-125x125.jpg", class: "img-thumbnail rounded-circle", style: "width: 50px;" %>
<%- end %>
</div>