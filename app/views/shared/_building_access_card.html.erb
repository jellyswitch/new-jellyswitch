<%= list_item do %>
  <h5 class="card-title">
    <% if @doors.count < 1 %>
      Check-in Instructions
    <% else %>
      <% if policy(:door).enabled? %>
        Building Access
      <% end %>
    <% end %>
  </h5>

  <% if policy(:door).enabled? %>
    <%= render(AccessInstructions::DoorButtons, operator: current_tenant, location: current_location, mobile_app_request: mobile_app_request?, show_doors: active_working_hours?(current_location) || has_building_access?(current_user), doors: @doors) %>
  <% end %>
<% end %>