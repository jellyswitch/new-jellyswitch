<div class="card border-light">
  <div class="card-body">
    <h5 class="card-title">
      Building Access
    </h5>
    <%= render "operator/doors/keys", doors: @doors %>
    <p class="card-text">
      <%= current_tenant.name %> is located at <%= link_to current_tenant.building_address, "https://maps.google.com/?q=#{current_tenant.building_address}", target: "_blank" %>. Please download the mobile app for building access once your membership or day pass has been approved.
    </p>
  </div>
</div>