<div class="card border-light">
  <div class="card-body">
    <h5 class="card-title">
      Need help?
    </h5>
    <p class="card-text">
      <%= current_tenant.name %> can be reached by emailing <%= mail_to current_tenant.contact_email, current_tenant.contact_name %>
      or calling <%= current_tenant.contact_phone %>.
    </p>
  </div>
</div>