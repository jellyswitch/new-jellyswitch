<%= form_for(subscription) do |f| %>
  <%= render "shared/error_messages", model: subscription %>
  
  <div class="form-group">
    <%= f.label :plan_id %>
    <%= f.select :plan_id, Plan.options_for_select, class: "form-control" %>
  </div>

  <div class="form-group">
    (credit card form goes here)
  </div>

  <br />
  <%= f.submit label, class: "btn btn-primary" %>
<%- end %>
