<div class="row">
  <div class="col"></div>
  <div class="col">
    <h2><%= @operator.name %></h2>
    <%= link_to "Edit", edit_operator_path(@operator), class: "btn btn-info" %>
    <table class="table">
      <tr>
        <th>Snippet</th>
        <td><%= @operator.snippet %></td>
      </tr>
      <tr>
        <th>Wifi Name</th>
        <td><%= @operator.wifi_name %></td>
      </tr>
      <tr>
        <th>Wifi Password</th>
        <td><%= @operator.wifi_password %></td>
      </tr>
      <tr>
        <th>Building Address</th>
        <td><%= @operator.building_address %></td>
      </tr>
      <tr>
        <th>Approval required for new members</th>
        <td><%= @operator.approval_required %></td>
      </tr>
      <tr>
        <th>Subdomain</th>
        <td><%= @operator.subdomain %></td>
      </tr>
      <tr>
        <th>Contact Name</th>
        <td><%= @operator.contact_name %></td>
      </tr>
      <tr>
        <th>Contact email</th>
        <td><%= @operator.contact_email %></td>
      </tr>
      <tr>
        <th>Square Footage</th>
        <td><%= @operator.square_footage %></td>
      </tr>
      <tr>
        <th>Kisi API Key</th>
        <td><%= @operator.kisi_api_key %></td>
      </tr>
      <tr>
        <th>Logo</th>
        <td>
          <%- if @operator.logo_image.attached? %>
            <%= image_tag(@operator.logo_image.variant(resize: "500x500")) %>
          <%- else %>
            <i>none</i>
          <%- end %>
        </td>
      </tr>
      <tr>
        <th>Background</th>
        <td>
          <%- if @operator.background_image.attached? %>
            <%= image_tag(@operator.background_image.variant(resize: "500x500")) %>
          <%- else %>
            <i>none</i>
          <%- end %>
        </td>
      </tr>
       <tr>
        <th>Contact phone number</th>
        <td><%= @operator.contact_phone %></td>
      </tr>
      <tr>
        <th>Email Enabled?</th>
        <th><%= @operator.email_enabled? %></th>
      </tr>
    </table>
  </div>
  <div class="col"></div>
</div>