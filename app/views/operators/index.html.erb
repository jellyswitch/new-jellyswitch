<div class="row">
  <div class="col"></div>
  <div class="col">
    <h2>Operators</h2>
    <%= link_to "New Operator", new_operator_path, class: "btn btn-primary btn-sm" %>
    <ul>
      <%- @operators.each do |operator| %>
        <li><%= link_to operator.name, operator_path(operator) %></li>
      <%- end %>
    </ul>
  </div>
  <div class="col"></div>
</div>