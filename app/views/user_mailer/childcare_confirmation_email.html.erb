<h1>Childcare Confirmation</h1>
<p>Hi <%= @user.name || "there" %>,</p>
<p>
This is a confirmation that you've booked childcare for <strong><%= @reservation.child_profile.name %></strong>. Your reservation details are below:
</p>
<p>
<strong>Slot:</strong> <%= @reservation.childcare_slot.pretty_name %><br>
<strong>Date:</strong> <%= @reservation.date.strftime("%m/%d/%Y") %>
</p>
<p>
Thanks, and have a great day!
</p>
<p>
<%= @operator.contact_name %>,<br>
<%= @operator.name %>
</p>
