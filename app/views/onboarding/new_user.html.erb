<% title "Sign Up" %>

<%= wide_card do %>
  <strong class="lead text-success">Step 1 of x</strong>
<% end %>

<%= wide_card do %>
  <h4 class="display-4 text-center mt-4">Sign up with your email address</h4>
  <%= form_with(url: create_user_onboarding_index_path, method: :post, local: true) do |f| %>
    <div class="row">
      <%= f.text_field :email, placeholder: "alice@awesomespace.com", class: "form-control col" %>
    </div>
    <div class="row mt-3">
      <%= f.submit "Begin onboarding", class: "btn btn-block btn-primary col" %>
    </div>
  <% end %>
<% end %>