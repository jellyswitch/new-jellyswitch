<%= form_for(:session, url: operator_login_create_path, remote: true) do |f| %>
  <% if flash[:error] %>
    <%= render "layouts/flash" %>
  <% end %>
  <div class="form-group row">
    <div class="col-1"></div>
    <%= f.email_field :email, placeholder: "Email", class: "form-control col" %>
    <div class="col-1"></div>
  </div>
  <div class="form-group row">
    <div class="col-1"></div>
    <%= f.password_field :password, placeholder: "Password", class: "form-control col" %>
    <div class="col-1"></div>
  </div>
  <div class="form-group row">
    <div class="col-1"></div>
    <%= f.submit "Sign In", class: "form-control btn btn-primary col" %>
    <div class="col-1"></div>
  </div>
  <div class="form-group col"></div>
    <div class="col-1"></div>
    <div class="col-sm-7 text-right">
      <small>
        Not a member? <%= link_to "Sign up", operator_signup_path %>
      </small>
    </div>
  <div class="col-1"></div>
<% end %>
