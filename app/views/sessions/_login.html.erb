<%= form_for(:session, url: login_path) do |f| %>
  <div class="form-group row">
    <%= f.label :email, class: "col-sm-2 text-right mt-2" %>
    <%= f.email_field :email, placeholder: "Email", class: "form-control col" %>
  </div>
  <div class="form-group row">
    <%= f.label :password, class: "col-sm-2 text-right mt-2" %>
    <%= f.password_field :password, placeholder: "Password", class: "form-control col" %>
  </div>
  <div class="form-group row">
    <div class="col-sm-2"></div>
    <div class="col-sm-7 text-right">
      <small>
        Not a member? <%= link_to "Sign up", signup_path %>
      </small>
    </div>
    <%= f.submit "Sign In", class: "form-control btn btn-primary col" %>
  </div>
<%- end %>
