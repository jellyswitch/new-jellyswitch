
<%- title "Day Pass Types" %>

<div class="row mt-3">
  <div class="col-sm-3"></div>
  <div class="col-sm">
    <div class="jumbotron bg-white pb-2 pt-2">
      <h4 class="display-4 text-center mt-4">Day Pass Types</h4>
      <%= link_to "Add a new day pass type", new_day_pass_type_path, class: "btn btn-primary btn-sm" %>
      <table class="table">
        <tr>
          <th>Name</th>
          <th>Price</th>
          <th>Actions</th>
        </tr>
        <% @day_pass_types.each do |day_pass_type| %>
          <tr>
            <td><%= day_pass_type.name %></td>
            <td><%= number_to_currency(day_pass_type.amount_in_cents.to_f / 100.0) %></td>
            <td>
              <%= render "actions", day_pass_type: day_pass_type %>
            </td>
          </tr>
        <% end %>
      </table>
    </div>
  </div>
  <div class="col-sm-3"></div>
</div>