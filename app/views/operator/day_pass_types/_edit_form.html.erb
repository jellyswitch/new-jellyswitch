<%= form_with(model: day_pass_type, url: url, remote: true) do |form| %>
  <%= render "shared/error_messages" , model: day_pass_type %>

  <div class="form-group">
    <%= form.label :name, "What is this day pass type called?" %>
    <%= form.text_field :name, placeholder: "Standard Day Pass", class: "form-control", disabled: true %>
  </div>

  <%= form.label :amount_in_cents, "How much does this day pass cost?" %>
  <div class="input-group">
    <div class="input-group-prepend">
      <span class="input-group-text">$</span>
    </div>
    <%= form.text_field :amount_in_cents, class: "form-control", disabled: true, value: day_pass_type.amount_in_cents / 100.0 %>
  </div>

  <div class="form-group">
    <%= form.label :code, "Discount Code (Optional)" %>
    <%= form.text_field :code, class: "form-control", placeholder: "CODE123" %>
  </div>

  <hr class="my-3">
  <h6>Meeting Room Limits</h6>

  <div class="form-group">
    <%= form.label :included_meeting_room_minutes, "Included Meeting Room Hours" %>
    <div class="input-group">
      <%= form.number_field :included_meeting_room_minutes, class: "form-control", placeholder: "e.g. 3", step: 0.5, min: 0, value: day_pass_type.included_meeting_room_minutes ? day_pass_type.included_meeting_room_minutes / 60.0 : nil %>
      <div class="input-group-append">
        <span class="input-group-text">hours</span>
      </div>
    </div>
    <small class="form-text text-muted">Leave blank for unlimited meeting room access.</small>
  </div>

  <div class="form-group">
    <%= form.label :overage_rate_in_cents, "Meeting Room Overage Rate" %>
    <div class="input-group">
      <div class="input-group-prepend">
        <span class="input-group-text">$</span>
      </div>
      <%= form.number_field :overage_rate_in_cents, class: "form-control", placeholder: "25.00", step: 0.01, min: 0, value: day_pass_type.overage_rate_in_cents > 0 ? day_pass_type.overage_rate_in_cents / 100.0 : nil %>
      <div class="input-group-append">
        <span class="input-group-text">/ hour</span>
      </div>
    </div>
    <small class="form-text text-muted">Charged in 30-minute increments.</small>
  </div>

  <hr class="my-3">

  <div class="form-group">
    <%= form.label :description %>
    <%= form.rich_text_area :description %>
  </div>

  <button class="form-control btn btn-primary" id="submit">
    <span class="show-when-enabled">
      Update
    </span>
    <span class="show-when-disabled">
      Updating
    </span>
  </button>
<% end %>



