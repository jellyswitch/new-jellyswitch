<%= form_with(model: day_pass_type, url: url, remote: true) do |form| %>
  <%= render "shared/error_messages" , model: day_pass_type %>

  <div class="form-group">
    <%= form.label :name, "What is this day pass type called?" %>
    <%= form.text_field :name, placeholder: "Standard Day Pass", class: "form-control" %>
  </div>

  <%= form.label :amount_in_cents, "How much does this day pass cost?" %>
  <div class="input-group">
    <div class="input-group-prepend">
      <span class="input-group-text">$</span>
    </div>
    <%= form.text_field :amount_in_cents, class: "form-control" %>
  </div>

  <div class="form-group">
    <%= form.label :code, "Discount Code (Optional)" %>
    <%= form.text_field :code, class: "form-control", placeholder: "CODE123" %>
  </div>

  <div class="form-group">
    <div class="form-check">
      <%= form.check_box :available, class: "form-check-input" %>
      <%= form.label :available, "Check this box if you want this day pass type to be available right away", class: "form-check-label" %>
    </div>

    <div class="form-check">
      <%= form.check_box :visible, class: "form-check-input" %>
      <%= form.label :visible, "Check this box if you want this day pass type to be visible to new members", class: "form-check-label" %>
    </div>

    <div class="form-check">
      <%= form.check_box :always_allow_building_access,   class: "form-check-input" %>
      <%= form.label :always_allow_building_access, "Check this box if members on this plan should be granted 24/7 building access", class: "form-check-label" %>
    </div>

  </div>

  <hr class="my-3">
  <h6>Meeting Room Limits</h6>

  <div class="form-group">
    <%= form.label :included_meeting_room_minutes, "Included Meeting Room Hours" %>
    <div class="input-group">
      <%= form.number_field :included_meeting_room_minutes, class: "form-control", placeholder: "e.g. 3", step: 0.5, min: 0 %>
      <div class="input-group-append">
        <span class="input-group-text">hours</span>
      </div>
    </div>
    <small class="form-text text-muted">Leave blank for unlimited meeting room access. If set, bookings beyond this limit will incur overage charges.</small>
  </div>

  <div class="form-group">
    <%= form.label :overage_rate_in_cents, "Meeting Room Overage Rate" %>
    <div class="input-group">
      <div class="input-group-prepend">
        <span class="input-group-text">$</span>
      </div>
      <%= form.number_field :overage_rate_in_cents, class: "form-control", placeholder: "25.00", step: 0.01, min: 0 %>
      <div class="input-group-append">
        <span class="input-group-text">/ hour</span>
      </div>
    </div>
    <small class="form-text text-muted">Charged in 30-minute increments. Only applies if meeting room hours limit is set above.</small>
  </div>

  <hr class="my-3">

  <div class="form-group">
    <%= form.label :description %>
    <%= form.rich_text_area :description %>
  </div>

  <%= form.submit "Add day pass type and add another", class: "form-control btn btn-primary mb-2", name: "add_day_pass_type_and_add_another" %>
  <%= form.submit "Just add this day pass type", class: "form-control btn btn-outline-primary", name: "add_day_pass_type" %>
<% end %>



