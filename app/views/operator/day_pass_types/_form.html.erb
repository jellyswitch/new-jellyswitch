<%= form_with(model: day_pass_type, remote: true) do |form| %>
  <%= render "shared/error_messages" , model: day_pass_type %>

  <div class="form-group">
    <%= form.label :name %>
    <%= form.text_field :name, class: "form-control" %>
  </div>

  <div class="form-group">
    <%= form.label :amount_in_cents %>
    <%= form.number_field :amount_in_cents, class: "form-control" %>
  </div>

  <div class="form-group">
    <div class="form-check">
      <%= form.check_box :available, class: "form-check-input" %>
      <%= form.label :available, class: "form-check-label" %>
    </div>

    <div class="form-check">
      <%= form.check_box :visible, class: "form-check-input" %>
      <%= form.label :visible, class: "form-check-label" %>
    </div>

    <div class="form-check">
      <%= form.check_box :always_allow_building_access, class: "form-check-input" %>
      <%= form.label :always_allow_building_access, class: "form-check-label" %>
    </div>
  </div>

  <%= form.submit "Create", class: "btn btn-primary" %>
<% end %>



