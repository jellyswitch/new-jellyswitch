<%= form_for(@organization, remote: true) do |f| %>
  <%= render "shared/error_messages" , model: @organization %>

  <div class="form-group">
    <%= f.label :name %>
    <%= f.text_field :name, class: "form-control" %>
  </div>

  <div class="form-group">
    <%= f.label :website %>
    <%= f.text_field :website, class: "form-control" %>
  </div>
  <div class="form-group">
    <%= f.label :owner %>
    <%= f.select :owner_id, User.lease_options_for_select(current_tenant), class: "form-control" %>
  </div>

  <div class="form-group">
    <%= f.label :billing_contact %>
    <% if @organization.can_change_billing_contact? %>

      <%= f.select :billing_contact_id, User.lease_options_for_select(current_tenant), class: "form-control" %>

    <% else %>

      <%= f.select :billing_contact_id, User.lease_options_for_select(current_tenant), {}, { disabled: true } %>

      <strong>Before you can change the billing contact, the following must first be cancelled:</strong>

      <% @organization.active_user_subscriptions.each do |subscription| %>
        <li class="list-group-item"><%=link_to "Subscription #{subscription.id} - #{subscription.subscribable.name} - #{subscription.plan.name}", user_membership_path(user_id: subscription.subscribable) %></li>
      <% end %>

      <% @organization.active_leases.each do |office_lease| %>
        <li class="list-group-item"><%= link_to "Office Lease ##{office_lease.id} - #{office_lease.office.name}", office_lease_path(office_lease) %></li>
      <% end %>

    <% end %>
  </div>

  <%= f.submit label, class: "form-control btn btn-primary" %>
<% end %>
