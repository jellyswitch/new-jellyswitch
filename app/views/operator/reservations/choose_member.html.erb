<% title "Choose a Member" %>

<%= breadcrumb do %>
  <li class="breadcrumb-item active" aria-current="page">Choose a Member</li>
<% end %>

<%= render Layout::FullWidth.new do %>
  <%= list_item do %>
    <h4 class="display-4 text-center">Choose a Member</h4>

    <dl class="row">
      <dt class="col-6">Room</dt>
      <dd class="col"><%= @room.name %></dd>
    </dl>

    <%= form_with url: @next_step_path, method: :get, local: true do |f| %>
      <div class="form-group">
        <%= f.label :user, "Select Member" %>
        <input type="text" id="member-search" class="form-control mb-2" placeholder="Search by name..." autocomplete="off"
               oninput="filterMembers(this.value)">
        <input type="hidden" name="user_id" id="user-id-hidden" value="<%= current_user.id %>">

        <div class="member-list" id="member-list">
          <% @member_options.each do |name, id| %>
            <div class="member-item<%= ' active' if id == current_user.id %>"
                 data-id="<%= id %>"
                 data-name="<%= name.downcase %>"
                 onclick="selectMember(this, '<%= id %>')">
              <%= name %>
            </div>
          <% end %>
          <% if @member_options.empty? %>
            <div class="member-no-results">No members available</div>
          <% end %>
        </div>
      </div>

      <%= f.hidden_field :room_id, value: @room.id %>
      <%= f.hidden_field :day, value: params[:day] %>
      <%= f.hidden_field :hour, value: params[:hour] %>

      <%= f.submit "Next", class: "btn btn-primary btn-block mt-3" %>
    <% end %>
  <% end %>
<% end %>

<style>
  .member-list {
    border: 1px solid #dee2e6;
    border-radius: .25rem;
    max-height: 300px;
    overflow-y: auto;
    background: #fff;
    -webkit-overflow-scrolling: touch;
  }
  .member-item {
    padding: 12px 14px;
    font-size: 16px;
    border-bottom: 1px solid #f0f0f0;
    cursor: pointer;
    -webkit-tap-highlight-color: rgba(0, 123, 255, 0.15);
    user-select: none;
    -webkit-user-select: none;
  }
  .member-item:last-child {
    border-bottom: none;
  }
  .member-item.active {
    background-color: #007bff;
    color: #fff;
    font-weight: 500;
  }
  .member-item:not(.active):active {
    background-color: #e9ecef;
  }
  .member-no-results {
    padding: 12px 14px;
    color: #6c757d;
    font-style: italic;
  }
</style>

<script>
  function selectMember(el, id) {
    document.getElementById("user-id-hidden").value = id;
    var items = document.querySelectorAll(".member-item");
    for (var i = 0; i < items.length; i++) {
      items[i].classList.remove("active");
    }
    el.classList.add("active");
  }

  function filterMembers(query) {
    var q = query.toLowerCase().trim();
    var items = document.querySelectorAll(".member-item");
    var anyVisible = false;
    for (var i = 0; i < items.length; i++) {
      var name = items[i].getAttribute("data-name");
      if (q === "" || name.indexOf(q) !== -1) {
        items[i].style.display = "";
        anyVisible = true;
      } else {
        items[i].style.display = "none";
      }
    }
  }
</script>
