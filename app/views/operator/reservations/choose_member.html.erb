<% title "Choose a Member" %>

<%= breadcrumb do %>
  <li class="breadcrumb-item active" aria-current="page">Choose a Member</li>
<% end %>

<%= render Layout::FullWidth.new do %>
  <%= list_item do %>
    <h4 class="display-4 text-center">Choose a Member</h4>

    <dl class="row">
      <dt class="col-6">Room</dt>
      <dd class="col"><%= @room.name %></dd>
    </dl>

    <%= form_with url: @next_step_path, method: :get, local: true do |f| %>
      <div class="form-group">
        <%= f.label :user, "Select Member" %>
        <input type="text" id="member-search" class="form-control mb-2" placeholder="Search by name..." autocomplete="off">
        <input type="hidden" name="user_id" id="user-id-hidden" value="<%= current_user.id %>">
        <div class="member-list" id="member-list"></div>
      </div>

      <%= f.hidden_field :room_id, value: @room.id %>
      <%= f.hidden_field :day, value: params[:day] %>
      <%= f.hidden_field :hour, value: params[:hour] %>

      <%= f.submit "Next", class: "btn btn-primary btn-block mt-3" %>
    <% end %>
  <% end %>
<% end %>

<style>
  .member-list {
    border: 1px solid #dee2e6;
    border-radius: .25rem;
    max-height: 300px;
    overflow-y: auto;
    background: #fff;
    -webkit-overflow-scrolling: touch;
  }
  .member-item {
    padding: 12px 14px;
    font-size: 16px;
    border-bottom: 1px solid #f0f0f0;
    cursor: pointer;
    -webkit-tap-highlight-color: rgba(0, 123, 255, 0.15);
    user-select: none;
    -webkit-user-select: none;
  }
  .member-item:last-child {
    border-bottom: none;
  }
  .member-item.active {
    background-color: #007bff;
    color: #fff;
    font-weight: 500;
  }
  .member-item:not(.active):active {
    background-color: #e9ecef;
  }
  .member-no-results {
    padding: 12px 14px;
    color: #6c757d;
    font-style: italic;
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    var searchInput = document.getElementById("member-search");
    var listContainer = document.getElementById("member-list");
    var hiddenInput = document.getElementById("user-id-hidden");

    var allMembers = <%= raw @member_options.map { |name, id| { name: name, id: id } }.to_json %>;
    var selectedId = String(hiddenInput.value);

    function renderList(query) {
      listContainer.innerHTML = "";
      var q = (query || "").toLowerCase().trim();

      var filtered = allMembers.filter(function(m) {
        return q === "" || m.name.toLowerCase().indexOf(q) !== -1;
      });

      if (filtered.length === 0) {
        var noResults = document.createElement("div");
        noResults.className = "member-no-results";
        noResults.textContent = "No members found";
        listContainer.appendChild(noResults);
        return;
      }

      filtered.forEach(function(m) {
        var item = document.createElement("div");
        item.className = "member-item";
        item.textContent = m.name;
        item.setAttribute("data-id", String(m.id));

        if (String(m.id) === selectedId) {
          item.classList.add("active");
        }

        item.addEventListener("click", function() {
          selectedId = String(m.id);
          hiddenInput.value = m.id;

          // Update all items
          var items = listContainer.querySelectorAll(".member-item");
          items.forEach(function(el) { el.classList.remove("active"); });
          item.classList.add("active");

          // Scroll the selected item into view
          item.scrollIntoView({ block: "nearest" });
        });

        listContainer.appendChild(item);
      });
    }

    searchInput.addEventListener("input", function() {
      renderList(this.value);
    });

    // Render full list on load with admin pre-selected
    renderList("");
  });
</script>
