<%= javascript_include_tag "reservation_details.js" %>

<li class="list-group-item row border-bottom-0">
  <p class="lead font-weight-bold">
    Room:
    <span class="font-weight-normal" >
     <%= reservation.room.decorate.smart_link %>
    </span>
  </p>

  <p class="lead font-weight-bold">
    Time:
    <span class="font-weight-normal">
     <%= pretty_datetime(reservation.datetime_in) %> - <%= pretty_datetime(reservation.datetime_out) %>
    </span>
  </p>

  <p class="lead font-weight-bold">
    Duration:
    <span class="font-weight-normal">
      <%= reservation.minutes %> minutes
    </span>
  </p>

  <p class="lead font-weight-bold">
    User:
    <span class="font-weight-normal">
      <%- if reservation.user.present? %>
        <%= link_to reservation.user.name, user_path(reservation.user) %>
      <%- else %>
        <i>Deleted user</i>
      <%- end %>
    </span>
  </p>

  <%- if reservation.cancelled? %>
    <p class="font-weight-bold">
      Status:
      <span class="badge badge-warning">Cancelled</span>
    </p>
  <%- end %>

  <%- if reservation.ended_early? %>
    <p class="font-weight-bold">
      Status:
      <span class="badge badge-warning">Ended Early</span>
    </p>
  <%- end %>

  <%- if !policy(reservation).destroy? && reservation.future? %>
    <p class="font-weight-bold text-sm">Note: <span class="font-weight-normal font-italic">If you want to cancel this paid reservation room, please contact our workspace admin for assistance.</span></p>
  <%- end %>

  <%- if policy(reservation).extend_reservation? %>
    <div class="text-center mt-3">
      <button id="extend-button" type="button" class="btn btn-block btn-primary mb-2" data-toggle="modal" data-target="#extend-reservation-modal" data-reservation-id="<%= reservation.id %>">
        Extend booking time
      </button>
    </div>
  <%- end %>

  <%- if reservation.ongoing? %>
    <button id="end-early-button" type="button" class="btn btn-block btn-danger" data-toggle="modal" data-target="#end-early-modal" <%= 'disabled' unless policy(reservation).end_now? %> data-reservation-id="<%= reservation.id %>">
      End reservation now
    </button>
  <%- end %>

  <%- if policy(reservation).cancel? %>
    <button type="button" data-toggle="modal" data-target="#cancel-reservation-modal" class="btn btn-block btn-danger" <%= 'disabled' unless policy(reservation).destroy? %>>Cancel this reservation</button>
  <%- end %>
</li>

<!-- Modal -->
<div class="modal fade" id="cancel-reservation-modal" tabindex="-1" role="dialog" aria-labelledby="cancelReservationTitle" aria-hidden="true">
  <div class="modal-dialog" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="cancelReservationTitle">Cancel Reservation</h5>
        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
          <span aria-hidden="true">&times;</span>
        </button>
      </div>
      <div class="modal-body">
        <p>
          Are you sure you want to cancel your reservation for
          <strong><%= reservation.room.name%>?</strong>
        </p>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
        <%= link_to "Confirm", reservation_path(reservation), method: :delete, remote: true, class: "btn btn-dark" %>
      </div>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="extend-reservation-modal" tabindex="-1" role="dialog" aria-labelledby="extendReservationModalLabel" aria-hidden="true">
  <div class="modal-dialog mt" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <h6 class="modal-title" id="extendReservationModalLabel">Extend Reservation</h6>
        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
          <span aria-hidden="true">&times;</span>
        </button>
      </div>

      <%= form_with(url: extend_reservation_reservation_path, method: :put, local: true) do |f| %>
        <div class="modal-body">
          <label for="duration" class="font-weight-bold">Select Additional Duration:</label>
          <select name="duration" id="extension-duration" class="form-control">
            <option value="30" class="duration-slot">30 minutes</option>
            <option value="60" class="duration-slot">1 hour</option>
            <option value="90" class="duration-slot">1 hour and 30 minutes</option>
            <option value="120" class="duration-slot">2 hours</option>
            <option value="180" class="duration-slot">3 hours</option>
            <option value="240" class="duration-slot">4 hours</option>
            <option value="480" class="duration-slot">8 hours</option>
          </select>
          <small class="form-text text-muted">Unavailable options will be disabled.</small>

          <div class="mt-3">
            <label class="font-weight-bold">Reservation Details Preview</label>
            <p class="mb-1 d-flex justify-content-between" style="font-weight: 500">End Time:
              <span id="new-reservation-end-time" class="font-weight-normal"></span>
            </p>

            <p class="mb-1 d-flex justify-content-between" style="font-weight: 500">Additional Price:
              <span id="additional-price" class="font-weight-normal"></span>
            </p>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
          <button type="submit" class="btn btn-primary" id="confirm-extension">Pay & Confirm</button>
        </div>
      <% end %>
    </div>
  </div>
</div>

<div class="modal fade" id="end-early-modal" tabindex="-1" role="dialog" aria-labelledby="endEarlyModalLabel" aria-hidden="true">
  <div class="modal-dialog" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="endEarlyModalLabel">End Reservation</h5>
        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
          <span aria-hidden="true">&times;</span>
        </button>
      </div>
      <div class="modal-body">
        <p>Are you sure you want to end this reservation early? This action cannot be undone.</p>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
        <%= link_to "Confirm", end_now_reservation_path(reservation), method: :put, class: "btn btn-primary", data: { turbo: false } %>
      </div>
    </div>
  </div>
</div>