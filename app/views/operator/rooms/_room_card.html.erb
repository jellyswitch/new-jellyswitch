<div class="card border-light">
  <div class="card-body">
    <div class="row">
      <div>
        <%= image_tag room.square_photo, class: "img-thumbnail", style: "max-height: 100px;" %>
      </div>
      <div class="ml-4 mb-1">
        <div class="row">
          <h5 class="display-5">
            <%= link_to room.name, room_path(room) %>
            <%- if admin? %>
              <%= link_to room_url(room, protocol: :webcal, format: :ics), class: "mt-1 ml-1" do %>
                <%= octicon "calendar", height: 15, width: 15 %>
              <%- end %>
            <%- end %>
          </h5>
        </div>
        <div class="row">
          <%- if room.whiteboard? %>
            <span class="badge badge-info mr-1">Whiteboard</span>
          <%- end  %>
          <%- if room.av? %>
            <span class="badge badge-success mr-1">AV equipment</span>
          <%- end %>
        </div>
        <div class="row">
          <p>Seats <strong><%= room.capacity %></strong> people</p>
        </div>
      </div>
    </div>

    <div class="row mt-3">
      <%- if room.available_now? %>
        <%= render "reservation_button", room: room, datetime_in: Time.current.beginning_of_hour, label: "Reserve Now" %>
      <%- end %>
      &nbsp;
      <%= link_to "Reserve later", room_day_availability_path(room, day: Date.today.day, month: Date.today.month, year: Date.today.year), class: "btn btn-sm btn-primary" %>
      &nbsp;
      <%- if admin? %>
        <%= link_to "Edit Room", edit_room_path(room), class: "btn btn-warning btn-sm" %>
      <%- end %>
    </div>
  </div>
</div>