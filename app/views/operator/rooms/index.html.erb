<div class="row mt-3">
  <div class="col-sm-3"></div>
  <div class="col-sm">
    <div class="jumbotron bg-white pb-2 pt-2">
      <%- if admin? %>
        <div class="row mt-2 mb-2">
          <div class="col mr-auto">
            <%= link_to "Add a new room", new_room_path, class: "btn btn-primary" %>
          </div>
        </div>
      <%- end %>
      <%- @rooms.each do |room| %>
        <%= render "horizontal_room_card", room: room %>
      <%- end %>
    </div>
  </div>
  <div class="col-sm-3"></div>
</div>