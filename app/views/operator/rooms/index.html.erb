<% title "Reserve a room" %>

<div class="row mt-3">
  <div class="col-lg-3"></div>
  <div class="col-lg">
    <div class="jumbotron bg-white pb-2 pt-2">
      <% if admin? %>
        <p>
          Showing rooms for <strong><%= current_location.name %></strong>. Switch locations to manage rooms at other locations.
        </p>
        <div class="row mt-2 mb-2">
          <div class="col mr-auto">
            <%= link_to "Add a new room", new_room_path, class: "btn btn-primary" %>
          </div>
        </div>
        <%- if @hidden_rooms.count > 0 %>
          <h4 class="display-4 text-center">Hidden Rooms</h4>
          <%- @hidden_rooms.each do |room| %>
            <%= render "room_card", room: room %>
          <%- end %>
          <h4 class="display-4 text-center">Visible Rooms</h4>
        <%- end %>
      <% end %>
      <% @rooms.each do |room| %>
        <%= render "room_card", room: room %>
      <% end %>
    </div>
  </div>
  <div class="col-lg-3"></div>
</div>
