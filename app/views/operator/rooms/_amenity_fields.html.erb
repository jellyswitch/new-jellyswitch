<%= stylesheet_link_tag "amenity_fields", media: "all" %>

<div class="nested-fields">
    <div class="form-row mx-0 amenity-container">
        <div class="form-group name-group">
            <%= f.text_field :name, class: "form-control", placeholder: "Name" %>
        </div>
        <div class="form-group price-group">
            <div class="input-group">
                <div class="input-group-prepend">
                    <span class="input-group-text">$</span>
                </div>
                <%= f.number_field :price, class: "form-control regular-price", step: 0.1, min: "0", placeholder: "0.00", value: nil %>
                <%= f.number_field :membership_price, class: "form-control membership-price ml-0", step: 0.1, min: "0", placeholder: "0.00", value: nil, style: "display: none;" %>
            </div>
        </div>
        <div class="form-group d-flex align-items-end">
            <%= link_to_remove_association "x", f, class: "btn btn-outline-danger" %>
        </div>
    </div>
</div>