<div class="row mt-3">
  <div class="col-3"></div>
  <div class="col">
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><%= link_to "Rooms", rooms_path %></li>
        <li class="breadcrumb-item"><%= @room.name %></li>
      </ol>
    </nav>
  </div>
  <div class="col-3"></div>
</div>

<div class="row mb-0">
  <div class="col-sm-3"></div>
  <div class="col-sm">
    <%= render "room_card", room: @room %>
  </div>
  <div class="col-sm-3"></div>
</div>


<div class="row mt-3">
  <div class="col-sm-3"></div>
  <div class="col-sm">
    <div class="jumbotron bg-white pb-2 pt-2">
      <h4 class="display-4 text-center mt-4">Reservations</h4>
      <%- if @room.reservations.count < 1 %>
        (none)
      <%- else %>
        <%- @room.reservations.each do |reservation| %>
          <div class="row">
            <div class="col-sm">
              <%= render "operator/reservations/reservation_card", reservation: reservation %>
            </div>
          </div>
        <%- end %>
      <%- end %>
    </div>
  </div>
  <div class="col-sm-3"></div>
</div>
