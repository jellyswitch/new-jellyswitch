<%- title "Edit #{@room.name}" %>

<div class="row mt-3">
  <div class="col-3"></div>
  <div class="col">
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><%= link_to "Rooms", rooms_path %></li>
        <li class="breadcrumb-item"><%= link_to @room.name, room_path(@room) %></li>
        <li class="breadcrumb-item active">Edit</li>
      </ol>
    </nav>
  </div>
  <div class="col-3"></div>
</div>

<div class="row">
  <div class="col-sm-3"></div>
  <div class="col-sm">
    <div class="jumbotron bg-white pb-2 pt-2">
      <h4 class="display-4 text-center mt-4">Edit Room</h4>
      <%= form_with(model: @room, url: room_path(@room), local: true) do |f| %>
        <%= render "shared/error_messages", model: room %>

        <%= render "operator/rooms/form_fields", f: f %>
        
        <%= f.submit "Update room", class: "btn btn-block btn-primary" %>
      <%- end %>

      <div class="row mt-3">
        <div class="col-12">
          <%- if !ios_request? %>
            <%= link_to "Cancel", room_path(@room), class: "btn btn-block btn-warning", data: {"turbolinks-action" => "replace"} %>
          <%- end %>
        </div>
      </div>
    </div>
  </div>
  <div class="col-sm-3"></div>
</div>