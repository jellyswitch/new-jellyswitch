<%= form_for(location, remote: true) do |f| %>
  <%= render "shared/error_messages" , model: location %>

  <div class="form-group ">
    <%= f.label :name %>
    <%= f.text_field :name, placeholder: "Name", class: "form-control" %>
  </div>

  <div class="form-group">
    <%= f.label :snippet, "Homepage Description" %>
    <%= f.text_field :snippet, placeholder: "Description", class: "form-control" %>
  </div>

  <div class="form-group">
    <%= f.label :allow_hourly, "Allow check-ins and check-outs at an hourly rate?" %>
    <%= f.check_box :allow_hourly, class: "form-control" %>
  </div>

  <div class="form-group">
    <%= f.label :hourly_rate_in_cents %>
    <%= f.number_field :hourly_rate_in_cents, placeholder: "300", class: "form-control" %>
  </div>

  <div class="form-group">
    <%= f.label :new_users_get_free_day_pass, "Automatically provision free day passes to new users??" %>
    <%= f.check_box :new_users_get_free_day_pass, class: "form-control" %>
  </div>

  <div class="form-group">
    <%= f.label :contact_name, "Contact Name (for members)" %>
    <%= f.text_field :contact_name, placeholder: "Contact Name", class: "form-control" %>
  </div>

  <div class="form-group">
    <%= f.label :contact_email, "Contact email (for members)" %>
    <%= f.text_field :contact_email, placeholder: "Contact Email", class: "form-control" %>
  </div>

  <div class="form-group">
    <%= f.label :contact_phone, "Contact phone number (for members)" %>
    <%= f.text_field :contact_phone, placeholder: "Contact Phone Number", class: "form-control" %>
  </div>

  <div class="form-group">
    <%= f.label :square_footage %>
    <%= f.number_field :square_footage, placeholder: "Square Footage", class: "form-control" %>
  </div>

  <div class="form-group">
    <%= f.label :flex_square_footage %>
    <%= f.number_field :flex_square_footage, placeholder: "Flex Square Footage", class: "form-control" %>
  </div>

  <div class="form-group">
    <%= f.label :common_square_footage %>
    <%= f.number_field :common_square_footage, placeholder: "Common Square Footage", class: "form-control" %>
  </div>

  <div class="form-group">
    <%= f.label :wifi_name %>
    <%= f.text_field :wifi_name, placeholder: "WiFi Name", class: "form-control" %>
  </div>

  <div class="form-group">
    <%= f.label :wifi_password %>
    <%= f.text_field :wifi_password, placeholder: "WiFi Password", class: "form-control" %>
  </div>

  <div class="form-group">
    <%= f.label :building_access_instructions %>
    <%= f.text_field :building_access_instructions, placeholder: "Please see a host for your key...", class: "form-control" %>
  </div>


  <div class="form-group">
    <%= f.label :building_address %>
    <%= f.text_field :building_address, placeholder: "Building Address", class: "form-control" %>
  </div>

  <div class="form-group">
    <%= f.label :city %>
    <%= f.text_field :city, class: "form-control" %>
  </div>

  <div class="form-group">
    <%= f.label :state %>
    <%= f.select :state, state_options, class: "form-control" %>
  </div>

  <div class="form-group">
    <%= f.label :zip %>
    <%= f.text_field :zip, class: "form-control" %>
  </div>

  <div class="form-group custom-file mb-3">
    <label class="custom-file-label" for="customFile">Choose background image</label>
    <%= f.file_field :background_image, placeholder: "Background Image File Path", class: "custom-file-input" %>
  </div>

  <div class="form-group">
    <%= f.label :time_zone %>
    <%= f.time_zone_select(:time_zone) %>
  </div>

  <div class="form-group">
    <%= f.label "Visible?" %>
    <%= f.check_box :visible, class: "form-control" %>
  </div>

  <%= f.submit label, class: "form-control btn btn-primary" %>
<% end %>
