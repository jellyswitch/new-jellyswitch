<%- title "Configure Door" %>

<% if !mobile_app_request? %>
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><%= link_to "Doors", doors_path %></li>
      <li class="breadcrumb-item"><%= link_to @door.name, door_path(@door) %></li>
      <li class="breadcrumb-item active">Configure</li>
    </ol>
  </nav>
<% end %>

<%= wide_card do %>
  <h4 class="display-4 text-center mt-4">Edit Door</h4>
  <%= render "form", label: "Update" %>
  <% if current_user.superadmin? %>
    <div class="row mt-2">
      <div class="col">
        <button type="button" class="btn btn-danger btn-block" data-toggle="modal" data-target="#delete-door-modal">
          Delete this door
        </button>
      </div>
    </div>

    <%= render Bootstrap::Modal.new(id: "delete-door-modal") do %>
      <h5 class="modal-title">Delete Door</h5>
      <div>
        <strong>Warning:</strong> This action cannot be undone. Deleting this door will permanently remove:
        <ul>
          <li>All door information (name, Kisi information, etc.)</li>
          <li>All access log history data</li>
        </ul>

        <%= button_to "Confirm", door_path(@door), method: :delete, class: "btn btn-block btn-danger" %>
      </div>    
    <% end %>
  <% end %>

  <div class="row mt-2">
    <div class="col-12">
      <%= link_to "Cancel", doors_path, class: "btn btn-block btn-warning" %>
    </div>
  </div>
<% end %>