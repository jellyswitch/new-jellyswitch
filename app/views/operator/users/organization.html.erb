<% title "Group Membership" %>

<div class="row mt-0 mb-0">
  <div class="col-lg-3"></div>
  <div class="col-lg-6 m-0 pl-0 pr-0">
    <%= list_wrapper do %>
      <%= list_item do %>
        
        <h4 class="display-4 text-center mt-2">Group</h4>
        <p>Select the correct group from the dropdown list to update this member's group.</p>
        <%= render "organization_form", user: @user %>
        
      <% end %>
    <% end %>
  </div>
  <div class="col-lg-3"></div>
</div>

