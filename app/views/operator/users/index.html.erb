<%- title "Member Directory" %>

<%= breadcrumb do %>
  <li class="breadcrumb-item"><%= link_to "Members & Groups", members_groups_path %></li>
  <li class="breadcrumb-item active" aria-current="page">Member Directory</li>
<% end %>

<div class="row mt-1 mb-0 p-0">
  <div class="col-lg-3"></div>
  <div class="col-lg-6 m-0 p-0">
    <%= list_wrapper do %>
      <%= list_item do %>
        <h4 class="display-4 text-center">Member Directory</h4>
        <% if policy(@users).index? %>
          <div class="row mb-3 mt-3">
            <div class="col">
              <%= link_to add_member_users_path, class: "btn btn-block btn-primary" do %>
                <i class="fas fa-users"></i>
                &nbsp;
                Add a member
              <% end %>
            </div>
          </div>
        <% end %>
      <% end %>

      <%= link_to unapproved_users_path, class: "list-group-item list-group-item-action d-flx m-0", style: "border-top: 0px;" do %>
        <i class="fas fa-hand-paper"></i>
        &nbsp;
        View approval queue (<%= @unapproved_users.count %> members)
      <% end %>

      <%= link_to archived_users_path, class: "list-group-item list-group-item-action d-flx m-0", style: "border-top: 0px;" do %>
        <i class="fas fa-archive"></i>
        &nbsp;
        View archived members (<%= @archived_users_count %> members)
      <% end %>

      <%= form_with(url: search_users_path, method: :get, local: true) do |f| %>
        <div class="form-group mx-3 mb-2 mt-4">
          <div class="input-group">
            <%= f.text_field :query, placeholder: "Search by name or email...", class: "form-control form-control col-lg", value: @query %>
            <div class="input-group-append">
              <%= button_tag(type: "submit", class: "btn btn-primary search-btn") do %>
                <i class="fas fa-search"></i>
              <% end %>
            </div>
          </div>
        </div>
      <%- end %>

      <% if @users.count < 1 %>
        <p class="text-center text-muted mt-2">No users found.</p>
      <% else %>
        <% @users.each_with_index do |user, index| %>
          <%= render "list_item", user: user, index: index %>
        <% end %>
        <%== pagy_bootstrap_nav(@pagy) %>
      <% end %>
    <% end %>
  </div>
  <div class="col-lg-3"></div>
</div>