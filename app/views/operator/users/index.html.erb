<%- if admin? %>
  <div class="row mt-3">
    <div class="col">
      <%= link_to "New Member", add_member_users_path, class: "btn btn-primary btn-sm" %>
    </div>
  </div>
<%- end %>

<%- @users.in_batches(of: 3) do |users| %>
  <div class="mt-3">
    <div class="card-deck">
      <%- [0,1,2].each do |i| %>
        <%- if users[i].present? %>
          <%= render "operator/users/member_card", member: users[i] %>
        <%- else %>
          <div class="card border-light"></div>
        <%- end %>
      <%- end %>
    </div>
  </div>
<%- end %>
