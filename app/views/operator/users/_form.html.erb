<%= form_with(model: @user, local: true) do |f| %>
  <%= render "shared/error_messages" , model: @user %>
  <div class="form-group row">
    <div class="col-1"></div>
    <%= f.text_field :name, placeholder: "Name", class: "form-control col" %>
    <div class="col-1"></div>
  </div>
  <div class="form-group row">
    <div class="col-1"></div>
    <%= f.email_field :email, placeholder: "Email", class: "form-control col" %>
    <div class="col-1"></div>
  </div>
  <div class="form-group row">
    <div class="col-1"></div>
    <%= f.text_field :phone, placeholder: "Phone Number", class: "form-control col" %>
    <div class="col-1"></div>
  </div>
  <div class="form-group row">
    <div class="col-1"></div>
    <%= f.password_field :password, placeholder: "Password", class: "form-control col" %>
    <div class="col-1"></div>
  </div>
  <div class="form-group row">
    <div class="col-1"></div>
    <%= f.password_field :password_confirmation, placeholder: "Confirm password", class: "form-control col" %>
    <div class="col-1"></div>
  </div>
  <div class="form-group row mb-0">
    <div class="col-1"></div>
    <%= f.label :original_location_id, "Main location", class: "col p-0 m-0" %>
    <div class="col-1"></div>
  </div>
  <div class="form-group row">
    <div class="col-1"></div>
    <%= f.select :original_location_id, options_for_select(@locations.map { |l| [l.name, l.id] }, current_location.id), {}, class: "form-control col" %>
    <div class="col-1"></div>
  </div>
  <div class="form-group row">
    <div class="col-1"></div>
    <%= f.submit label, class: "form-control btn btn-primary col", data: { acc: 'register' } %>
    <div class="col-1"></div>
  </div>
<%- end %>
