<div class="row mt-3 mb-3">
  <div class="col-sm-3"></div>
  <div class="card col-sm bg-light p-3">
    <div class="card-body">
      <h1>My Day Passes</h1>
      <% if policy(DayPass.new).new? %>
        <p>
          <%= link_to "Buy a day pass", new_day_pass_path, class: "btn btn-sm btn-primary" %>
        </p>
      <% end %>
      <table class="table table-sm">
        <% if @user.day_passes.count < 1 %>
          <p class="lead">(None)</p>
        <% end %>
        <% @user.day_passes.each do |day_pass| %>
          <tr>
            <td>
              <%= link_to day_pass.pretty_day, day_pass_path(day_pass) %>
            </td>
          </tr>
        <% end %>
      </table>
    </div>
  </div>
  <div class="col-sm-3"></div>
</div>
