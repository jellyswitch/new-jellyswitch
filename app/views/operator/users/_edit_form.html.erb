<%= form_with(model: @user, html: { multipart: true }, local: true, data: { type: :html }) do |f| %>
  <%= render "shared/error_messages", model: @user %>

  <h2>Basic Information</h2>
  <div class="form-group">
    <%= f.label :name %><small class="text-muted"> (required)</small>
    <%= f.text_field :name, class: "form-control" %>
  </div>
  <div class="form-group">
    <%= f.label :email %><small class="text-muted"> (required)</small>
    <%= f.email_field :email, class: "form-control" %>
  </div>
  <div class="form-group">
    <%= f.label :phone %>
    <%= f.telephone_field :phone, id: "phone-number", class: "form-control" %>
  </div>
  <div class="form-group">
    <%= f.label :password %><small class="text-muted"> (required)</small>
    <%= f.password_field :password, class: "form-control" %>
  </div>
  <div class="form-group">
    <%= f.label :password_confirmation, "Confirm password" %><small class="text-muted"> (required)</small>
    <%= f.password_field :password_confirmation, class: "form-control" %>
  </div>
  <div class="form-group">
    <%= f.label :profile_photo %>
    <%= f.file_field :profile_photo, class: "form-control-file" %>
  </div>
  <div class="form-group">
    <%= f.label :bio %>
    <%= f.text_area :bio, class: "form-control" %>
  </div>
  <%- if policy(@user).edit? %>
    <div class="form-group">
      <%= f.label :approved, class: "form-check-label" %>
      <%= f.check_box :approved, class: "form-check-box" %>
    </div>

    <% if policy(@user).edit_role? %>
      <div class="form-group">
        <%= f.label :role, class: "form-label" %>
        <%= f.select :role, options_for_select(current_user.role_options_for_select, selected: (current_user.role_options_for_select.select {|a| a.include?(@user.role)}.first) ), {}, class: "form-control" %>
      </div>

      <div class="form-group managed-location">
        <%= f.label :managed_location_ids, 'Managed Locations', class: "form-label" %>
        <%= f.select :managed_location_ids, options_for_select(current_user.managed_location_options_for_select, selected: @user.managed_location_ids), {}, multiple: true, class: "form-control" %>
      </div>
    <% end %>

    <div class="form-group">
      <%= f.label :always_allow_building_access, class: "form-check-label" %>
      <%= f.check_box :always_allow_building_access, class: "form-check-box" %>
    </div>
  <% end %>

  <h2>Contact Information</h2>

  <div class="form-group">
    <%= f.label :linkedin %>
    <%= f.text_field :linkedin, class: "form-control" %>
  </div>
  <div class="form-group">
    <%= f.label :twitter %>
    <%= f.text_field :twitter, class: "form-control" %>
  </div>
  <div class="form-group">
    <%= f.label :website %>
    <%= f.text_field :website, class: "form-control" %>
  </div>
  <%= f.submit label, class: "form-control btn btn-primary" %>
<% end %>
<script>
  $(document).ready(function() {
    $('#user_role').on('change', function() {
      if (['admin', 'general-manager', 'community-manager'].includes($(this).val())) {
        $('.managed-location').show();
      } else {
        $('.managed-location').hide();
      }
    }).trigger('change');
  });
</script>