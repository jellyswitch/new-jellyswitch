<div class="row mt-3 mb-3">
  <div class="col-sm-3"></div>
  <div class="card col-sm bg-light p-3">
    <div class="card-body">
      <h1>My Invoices</h1>
      <table class="table">
        <tr>
          <th>Invoice Date</th>
          <th>PDF</th>
        </tr>
        <%- @invoices.each do |invoice| %>
          <tr>
            <td><%= DateTime.strptime(invoice[:date].to_s,'%s').strftime("%m/%d/%Y") %></td>
            <td><%= link_to "Download Invoice", invoice[:invoice_pdf], class: "btn btn-primary btn-sm" %></td>
          </tr>
        <%- end %>
      </table>
    </div>
  </div>
  <div class="col-sm-3"></div>
</div>
