<div class="card border-light">
  <div class="card-body">
    <div class="row">
      <div>
        <%- if member.has_profile_photo? %>
          <%= image_tag member.square_profile_photo, class: "img-thumbnail" %>
        <%- else %>
          <%= image_tag "profile-125x125.jpg", class: "img-thumbnail", style: "height: 100px;" %>
        <%- end %>
      </div>
      <div class="ml-2 flex-grow-1">
        <p class="mb-1">
          <%- if policy(member).index? %>
            <%= link_to member.name, user_path(member) %>
          <%- else %>
            <%= member.name %>
          <%- end %>
        </p>
        <%= render "operator/users/social", user: member %>
        <%- if member.admin_of_location?(current_location) %>
          <span class="badge badge-success">Operator</span>
        <%- end %>
        <%- if !member.approved? %>
          <span class="badge badge-danger">Not Approved</span>
        <%- end %>
        <span class="badge badge-info">Member</span>
        <br />
      </div>
      <% if policy(member).remove_from_organization? && member.member_of_organization? %>
        <div class="ml-auto d-flex align-items-center">
          <%= link_to user_remove_from_organization_path(member), class: "btn btn-outline-danger btn-sm", data: { confirm: "Remove #{member.name} from this group?" } do %>
            <i class="fas fa-times"></i> Remove
          <% end %>
        </div>
      <% end %>
    </div>
    <div class="row">
      <p class="card-text"><%= member.bio %></p>
    </div>
  </div>
</div>