<% if user.approved? %>
  <%= link_to "Unapprove", user_unapprove_path(user), remote: true, data: {acc: 'approve-member'}, class: "btn btn-block btn-sm btn-outline-danger" %>
<% else %>
  <%= link_to "Approve", user_approve_path(user), remote: true, data: {acc: 'approve-member'}, class: "btn btn-block btn-sm btn-outline-success" %>
<% end %>
