<% if user.approved? %>
  <%= link_to "Unapprove", user_unapprove_path(user), remote: true, class: "btn btn-block btn-sm btn-outline-danger", data: {acc: 'unapprove-member'} %>
<% else %>
  <%= link_to "Approve", user_approve_path(user), remote: true, class: "btn btn-block btn-sm btn-outline-success", data: {acc: 'approve-member'} %>
<% end %>
