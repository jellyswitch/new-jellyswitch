<%- if admin? %>
  <dl class="row">
    <dt class="col-sm-3">Payment Method</dt>
    <dd class="col"><%= render "payment_method_form" %></dd>
  </dl>
  <dl class="row">
    <dt class="col-sm-3">Current Membership</dt>
    <dd class="col">
      <%= render "memberships", user: @user %>
    </dd>
  </dl>
  <dl class="row">
    <dt class="col-sm-3">Day Passes</dt>
    <dd class="col">
      <%= render "day_passes", user: @user %>
    </dd>
  </dl>  
  <dl class="row">
    <dt class="col-sm-3">Invoices</dt>
    <dd class="col">
      <%= render "invoices", user: @user %>
    </dd>
  </dl>  

<%- end %>
