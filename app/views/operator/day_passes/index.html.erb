<div class="row mt-3 mb-2">
  <div class="col-sm-3"></div>
  <div class="col-sm">
    <div class="card">
      <div class="card-body">
        <h4 class="display-4 text-center">Day Passes</h4>
        <table class="table table-sm">
          <%- @day_passes.each do |day_pass| %>
            <tr>
              <td>
                <%= day_pass.pretty_day %>
              </td>
              <td>
                <%= link_to day_pass.user.name, user_path(day_pass.user) %>
              </td>
            </tr>
          <%- end %>
        </table>  
      </div>
    </div>
  </div>
  <div class="col-sm-3"></div>
</div>
