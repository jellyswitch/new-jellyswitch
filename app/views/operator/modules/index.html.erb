<%- title "Modules" %>

<%= breadcrumb do %>
  <li class="breadcrumb-item"><%= link_to "Customization", customization_path %></li>
  <li class="breadcrumb-item active" aria-current="page">Modules</li>
<% end %>

<%= render(Layout::FullWidth) do %>
  <%= list_wrapper do %>
    
    <%= list_item do %>
      <h4 class="display-4 text-center">Modules</h4>

      <div class="row mb-3">
        <small class="col text-center">
          Enable and disable Jellyswitch modules to fully customize your experience.
        </small>
      </div>

      <div class="row">
        <div class="col">
          <%= render(OnOffSwitch, predicate: policy(:announcement).enabled?, path: announcements_modules_path) do %>
            Announcements
          <% end %>
        </div>
      </div>

      <div class="row">
        <div class="col">
          <%= render(OnOffSwitch, predicate: policy(:room).enabled?, path: rooms_modules_path) do %>
            Rooms & Reservations
          <% end %>
        </div>
      </div>

      <div class="row">
        <div class="col">
          <%= render(OnOffSwitch, predicate: policy(:office).enabled?, path: offices_modules_path) do %>
            Offices & Lease Management
          <% end %>
        </div>
      </div>
      
      <div class="row">
        <div class="col">
          <%= render(OnOffSwitch, predicate: policy(:event).enabled?, path: events_modules_path) do %>
            Events
          <% end %>
        </div>
      </div>

      <div class="row">
        <div class="col">
          <%= render(OnOffSwitch, predicate: policy(:door).enabled?, path: door_integration_modules_path) do %>
            Door Integration
          <% end %>
        </div>
      </div>



    <% end %>

    <% if superadmin? %>
      <%= list_item do %>
        <h4 class="display-4 text-center">Debug Info</h4>

        <% [:stripe_user_id, :stripe_publishable_key, :stripe_refresh_token, :stripe_access_token].each do |sym| %>
          <dl class="row">
            <dt class="col-lg-6"><%= sym.to_s %></dt>
            <dd class="col">
              <%= current_tenant.send(sym) %>
            </dd>
          </dl>
        <% end %>
        



      <% end %>
    <% end %>
  <% end %>
<% end %>

