<div class="text-center">
  <%= title "Stickied Feed Items" %>
</div>
<div class="d-flex flex-column justify-content-center align-items-center row mt-1 mb-0 p-0">
  <div class="col-lg-2 order-2 order-lg-1"></div>
  <div class="col-lg-6 order-3 order-lg-2 m-0 p-0">
    <% if @feed_items.count > 0 %>
      <%= list_wrapper do %>
        <% @feed_items.each do |feed_item| %>
          <div class="border-bottom" id="feed-item-<%= feed_item.id %>">
            <%= render(FeedItemComponent.new(feed_item: feed_item, comments: false)) %>
          </div>
        <% end %>
      <% end %>

    <% else %>
      <%= list_wrapper do %>
        <%= list_item do %>
          No feed items yet!
        <% end %>
      <% end %>
    <% end %>

  </div>
  <div class="col-lg-1 order-4"></div>
</div>