<%- case feed_item.type
    when "post" %>
  <%= render "post_feed_item", feed_item: feed_item %>
<%- when "reservation" %>
  <%= render "room_reservation_feed_item", feed_item: feed_item %>
<%- when "feedback" %>
  <%= render "member_feedback_feed_item", feed_item: feed_item %>
<%- when "day-pass" %>
  <%= render "day_pass_feed_item", feed_item: feed_item %>
<%- when "new-user" %>
  <%= render "new_user_feed_item", feed_item: feed_item %>
<%- end %>