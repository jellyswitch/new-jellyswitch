
<% if feed_item.type == "reservation" %>
  <% if policy(:notification).reservations? %>
    <%= render(FeedItemComponent.new(feed_item: feed_item, comments: comments)) %>
  <% end %>
<% elsif feed_item.type == "new-user" %>
<% else %>
  <%= render(FeedItemComponent.new(feed_item: feed_item, comments: comments)) %>
<% end %>