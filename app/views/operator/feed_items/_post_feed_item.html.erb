
<div class="row">
  <div>
    <%- if feed_item.user.has_profile_photo? %>
      <%= image_tag feed_item.user.square_profile_photo, class: "img-thumbnail", style: "height: 50px;" %>
    <%- else %>
      <%= image_tag "profile-125x125.jpg", class: "img-thumbnail", style: "height: 50px;" %>
    <%- end %>
  </div>
  <div class="ml-2">
    <p class="mb-1">
      <%= link_to feed_item.user.name, user_path(feed_item.user) %>
      <%- if feed_item.user.admin? %>
        <span class="badge badge-success">Operator</span>
      <%- end %>
      <br />
      <small>
        <%= link_to "#{time_ago_in_words(feed_item.created_at)} ago", feed_item_path(feed_item) %>
      </small>
    </p>
  </div>
  <div class="ml-auto">
    <%= render "common", feed_item: feed_item %>
  </div>
</div>

<%- if feed_item.expense? %>
  <div class="row mt-4">
    <span class="badge badge-danger">Expense: <%= number_to_currency(feed_item.amount.to_f / 100.0) %></span>
  </div>
<%- end %>


<div class="row mt-4">
  <p class="lead">
    <%= feed_item.text %>
  </p>
</div>

<%- if feed_item.has_photos? %>
  <div class="row mt-2">
    <%- feed_item.thumbnails.each do |photo| %>
      <%= image_tag photo, class: "img-fluid m-1", style: "max-height: 100px;" %>
    <%- end %>
  </div>
<%- end %>

<%= render "comments", feed_item: feed_item, show_comments: comments %>