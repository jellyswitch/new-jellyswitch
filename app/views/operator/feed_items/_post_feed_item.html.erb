<div class="row mb-0 mt-1">
  <div class="col-sm-3"></div>
  <div class="col-sm">
    <div class="card pl-2 pr-2">
      <div class="card-body">

        <div class="row">
          <div>
            <%- if feed_item.user.has_profile_photo? %>
              <%= image_tag feed_item.user.square_profile_photo, class: "img-thumbnail", style: "height: 50px;" %>
            <%- else %>
              <%= image_tag "profile-125x125.jpg", class: "img-thumbnail", style: "height: 50px;" %>
            <%- end %>
          </div>
          <div class="ml-2">
            <p class="mb-1">
              <%= link_to feed_item.user.name, user_path(feed_item.user) %>
              <br />
              <small>
                <%= link_to "#{time_ago_in_words(feed_item.created_at)} ago", feed_item_path(feed_item) %>
              </small>
            </p>
          </div>
        </div>

        <div class="row mt-2">
          <p class="lead">
            <%= feed_item.text %>
          </p>
        </div>
        
        <%- if feed_item.has_photos? %>
          <div class="row mt-2">
            <%- feed_item.thumbnails.each do |photo| %>
              <%= image_tag photo, class: "img-fluid m-1", style: "max-height: 100px;" %>
            <%- end %>
          </div>
        <%- end %>

      </div>
    </div>
  </div>
  <div class="col-sm-3"></div>
</div>