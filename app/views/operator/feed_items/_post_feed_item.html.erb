
<div class="row">
  <div>
    <%= render "shared/small_profile_photo", user: feed_item.user %>
  </div>
  <div class="ml-2">
    <p class="mb-1">
      <%= link_to feed_item.user.name, user_path(feed_item.user) %>
      <br />
      <small>
        <%= link_to "#{time_ago_in_words(feed_item.created_at)} ago", feed_item_path(feed_item) %>
      </small>
    </p>
  </div>
  <div class="ml-auto">
    <%= render "operator/feed_items/common", feed_item: feed_item %>
  </div>
</div>

<%- if feed_item.expense? %>
  <div id= "badge-expense-status-<%=feed_item.id%>">
    <div class="row mt-4">
      <span class="badge badge-danger">Expense: <%= number_to_currency(feed_item.amount.to_f / 100.0) %></span>
    </div>
  </div>
<%- end %>


<div class="row mt-4">
  <p class="lead">
    <%= feed_item.text %>
  </p>
</div>

<%- if feed_item.has_photos? %>
  <div class="row mt-2">
    <div class="col">
    <%- feed_item.feed_photos.each do |photo| %>
      <%= image_tag photo, class: "img-fluid" %>
    <%- end %>
    </div>
  </div>
<%- end %>

<%= render "operator/feed_items/comments", feed_item: feed_item, show_comments: comments %>