<div class="row mt-3 mb-2">
  <div class="col-lg-2 d-none d-lg-block"></div>
  <div class="col-lg-3 d-lg-none mb-3">
    <%= render "sidebar" %>
  </div>
  <div class="col-lg-6">

    <div class="card">
      <div class="card-body">
        <h4 class="display-4 text-center">Management Log</h4>
        <%= render "form", feed_item: @feed_item %>
      </div>
    </div>

    <%- @feed_items.each do |feed_item| %>
      <%= render "feed_item", feed_item: feed_item %>
    <%- end %>

  </div>
  <div class="col-lg-3 d-none d-lg-block">
    <%= render "sidebar" %>
  </div>

  <div class="col-lg-1"></div>
</div>

