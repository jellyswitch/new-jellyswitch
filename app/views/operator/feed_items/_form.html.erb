<%= form_for(feed_item, remote: true) do |f| %>
  <%= render "shared/error_messages" , model: feed_item %>
  <div class="form-group row">
    <div class="col-1"></div>
    <%= f.text_area :original_text, placeholder: "What are you up to?", class: "form-control col" %>
    <div class="col-1"></div>
  </div>
  <div class="form-group row">
    <div class="col-1"></div>
    <%= f.submit "Post", class: "form-control btn btn-primary col" %>
    <div class="col-1"></div>
  </div>
<%- end %>
