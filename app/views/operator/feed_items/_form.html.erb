<%= form_for(feed_item, html: {multipart: true}, local: mobile_app_request? && ios_request?, data: { type: :html }) do |f| %>
  <%= render "shared/error_messages" , model: feed_item %>
  <div class="form-group row m-0 p-0 mt-0">
    <%= f.text_area :text, placeholder: "Type a new management note or announcement...", class: "form-control form-control-lg col", rows: "6", id: "text" %>
  </div>
  <div class="form-group row m-0 p-0 mt-2">
    
    <div class="col pl-0 m-0">
      <%= f.label :photos, "Attach photos" do %>
        <span class="btn btn-sm btn-info">Attach photos</span>
        <%= f.file_field :photos,
                         multiple: true,
                         direct_upload: false,
                         accept: 'image/png,image/gif,image/jpeg,image/jpg',
                         class: "form-control-file d-none"
        %>
      <%- end %>
    </div>
    
  </div>
  <div class="form-group row m-0 p-0">
    
      <div class="btn-group" role="group">
        <%= f.submit "Post management note", class: "form-control btn btn-primary", id: "submit", name: "mgmt_note" %>

        <div class="btn-group" role="group">
          <button id="btnGroupDrop1" type="button" class="btn btn-success dropdown-toggle" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
            More
          </button>
          <div class="dropdown-menu dropdown-menu-right" aria-labelledby="btnGroupDrop1">
            <%= f.submit "Post announcement", class: "dropdown-item", id: "announcement_submit", name: "announcement" %>
          </div>
        </div>
      </div>
    
  </div>
<%- end %>


<%= render "shared/disable_button", submit_id: "#submit", text_id: "#text" %>
<%= render "shared/disable_button", submit_id: "#btnGroupDrop1", text_id: "#text" %>