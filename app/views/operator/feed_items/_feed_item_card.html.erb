<%= list_item do %>
  <div class="row">
    <div class="col-2">
      <%= render "shared/small_profile_photo", user: feed_item.user %>
    </div>
    <div class="col">
      <div class="ml-0">
        <p class="mb-1">
          <%= link_to feed_item.user.name, user_path(feed_item.user) %> <small><%= feed_item.action_text %></small>
          <div class="clearfix"></div>
          <%= link_to "#{time_ago_in_words(feed_item.created_at)} ago", feed_item_path(feed_item), class: "small" %>
        </p>
      </div>
    </div>
  </div>
  <div class="row">
    <div class="col-2"></div>
    <div class="col">
      <%= render "operator/feed_items/#{feed_item.type.underscore}_feed_item", feed_item: feed_item %>
    </div>
  </div>
  
  <%= render "operator/feed_items/common", feed_item: feed_item, comments: comments %>

<% end %>