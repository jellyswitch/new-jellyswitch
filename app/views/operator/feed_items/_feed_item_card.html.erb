<%= list_item do %>
  <div class="row">
    <div class="col-2">
      <%= render "shared/small_profile_photo", user: feed_item.user %>
    </div>
    <div class="col">
      <div class="ml-0">
        <span class="mb-1">
          <div class="row">
            <div class="col">
              <%= content_for :user do %>
                <%= link_to feed_item.user.name, user_path(feed_item.user) %> 
              <% end %>
              <small><%= feed_item.action_text %></small>
            </div>
          </div>
          <div class="row" style="margin-top: -5px;">
            <div class="col">
              <%= link_to "#{time_ago_in_words(feed_item.created_at)} ago", feed_item_path(feed_item), class: "small" %>
            </div>
          </div>
        </span>
      </div>
    </div>
  </div>
  <div class="row mt-3">
    <div class="col-2"></div>
    <div class="col">
      <%= render "operator/feed_items/#{feed_item.type.underscore}_feed_item", feed_item: feed_item %>
    </div>
  </div>
  
  <%= render "operator/feed_items/common", feed_item: feed_item, comments: comments %>

<% end %>