<% title "Childcare Slot" %>

<%= render Layout::FullWidth do %>
  <%= list_item do %>
    <h4 class="display-4 text-center">
      Childcare Slot
    </h4>

    <%= render(Childcare::Slot, childcare_slot: @childcare_slot) %>

    <% if @childcare_slot.visible? %>
      <%= link_to "Delete", childcare_slot_path(@childcare_slot), method: :delete, class: "btn btn-block btn-danger" %>
    <% end %>
  <% end %>
<% end %>