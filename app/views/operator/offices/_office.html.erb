<div class="card border-light">
  <div class="card-body">
    <div class="row">
      <div>
        <% if office.has_photo? %>
          <%= image_tag office.square_photo, class: "img-thumbnail", style: "max-height: 100px;" %>
        <% end %>
      </div>
      <div class="ml-4 mb-1">
        <div class="row">
          <h5 class="display-5">
            <%= link_to office.name, office %>
          </h5>
        </div>
        <div class="row">
          <p>Seats <strong><%= office.capacity %></strong> people</p>
        </div>
        <div class="row">
          <p><%= office.description %></p>
        </div>
      </div>
      <div class="row mt-3">
        <div class="col">
          <% if admin? %>
            <div class="row mt-2">
              <div class="col m-0 pl-0">
                <%= link_to "Edit Office", edit_office_path(office), class: "btn btn-block btn-secondary" %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
