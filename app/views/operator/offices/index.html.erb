<% title "Offices" %>

<%= breadcrumb do %>
  <li class="breadcrumb-item"><%= link_to "Offices & Leases", offices_leases_path %></li>
  <li class="breadcrumb-item active" aria-current="page">Offices</li>
<% end %>

<%= wide_card do %>
  <h4 class="display-4 text-center">Available Offices</h4>
  <%= link_to "Add an office", new_office_path, class: 'btn btn-block btn-primary' %>
  <%= render @offices.available_for_lease %>
<% end %>

<%= wide_card do %>
  <h4 class="display-4 text-center">Occupied Offices</h4>

  <%= render @offices.occupied %>
<% end %>

