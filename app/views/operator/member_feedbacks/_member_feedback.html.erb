
<%= link_to member_feedback_path(member_feedback), class: "list-group-item list-group-item-action" do %>
  <div class="d-flex justify-content-between align-items-start">
    <div>
      <p class="lead mb-1"><%= truncate(member_feedback.comment, length: 100) %></p>
      <small class="text-muted">
        <%= time_ago_in_words(member_feedback.created_at) %> ago
        <% if member_feedback.feedback_replies.any? %>
          &middot; <%= member_feedback.feedback_replies.count %> <%= "reply".pluralize(member_feedback.feedback_replies.count) %>
        <% end %>
      </small>
    </div>
    <% if member_feedback.feedback_replies.any? %>
      <span class="badge badge-primary badge-pill"><%= member_feedback.feedback_replies.count %></span>
    <% end %>
  </div>
<% end %>
