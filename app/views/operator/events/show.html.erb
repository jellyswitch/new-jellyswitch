<% title @event.title %>

<%= breadcrumb do %>
  <li class="breadcrumb-item"><%= link_to "What's Happening?", events_path %></li>
  <li class="breadcrumb-item active" aria-current="page"><%= @event.title %></li>
<% end %>

<% if !mobile_app_request? && current_tenant.has_mobile_app_links? %>
  <div class="row mt-1">
    <div class="col-md-4"></div>
    <div class="col-md-2 text-center align-middle">
      <a href="<%= current_tenant.ios_url %>">
        <img alt="Get it on the app store" src="https://linkmaker.itunes.apple.com/en-us/badge-lrg.svg?releaseDate=2019-03-26&kind=iossoftware&bubble=ios_apps" width=135 height=40>
      </a>
    </div>

    <div class="col-md-2 text-center align-middle" style="margin-top: -10px;">
      <a href="<%= current_tenant.android_url %>">
        <img alt='Get it on Google Play' src="https://play.google.com/intl/en_us/badges/images/generic/en_badge_web_generic.png" height=60>
      </a>
    </div>
    <div class="col-md-4"></div>
  </div>
<% end %>

<%= render @event %>

<% if !logged_in? %>
  <div class="row mt-1 mb-0 p-0">
    <div class="col-lg-3"></div>
    <div class="col-lg-6 m-0 p-0">
      <%= list_wrapper do %>
        <%= link_to events_path(location_id: @event.location), class: "list-group-item list-group-item-action m-0", style: "border-top: 0px;" do %>
          <div class="row">
            <div class="col-2">
              <%= image_tag current_tenant.logo_image, width: 50, height: 50 if current_tenant.logo_image.attached? %>
            </div>
            <div class="col-9">
              See what else is happening at <%= current_tenant.name %>!
            </div>
            <div class="col-1">
              <i class="fas fa-chevron-right"></i>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
    <div class="col-lg-3"></div>
  </div>
<% end %>