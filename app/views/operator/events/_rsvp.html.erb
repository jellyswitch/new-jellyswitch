<% if policy(event).rsvp? %>
  <div class="row mt-3">
    <div class="col">
      <h5 class="">Are you going?</h5>
    </div>
  </div>
  <div class="row mt-2 mb-3">
    <div class="col">
      <%= link_to going_event_rsvps_path(event_id: event.id), class: "btn btn-block btn-success" do %>
        <i class="fas fa-check"></i>
        &nbsp;
        I'm going
      <% end %>
    </div>
    <div class="col">
      <%= link_to not_going_event_rsvps_path(event_id: event.id), class: "btn btn-block btn-secondary" do %>
        <i class="fas fa-times"></i>
        &nbsp;
        I'm not going
      <% end %>
    </div>
  </div>
<% end %>

