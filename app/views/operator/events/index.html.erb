
<% title "What's Happening?" %>

<div class="row mt-1 mb-0 p-0">
  <div class="col-lg-3"></div>
  <div class="col-lg-6 m-0 p-0">
    <%= list_wrapper do %>
      <%= list_item do %>
        <h4 class="display-4 text-center">What's Happening?</h4>
        <%= link_to new_event_path, class: "btn btn-block btn-primary" do %>
          <i class="far fa-calendar-alt"></i>
          &nbsp;
          Create an event
        <% end %>
      <% end %>

      <%= link_to past_events_path, class: "list-group-item list-group-item-action d-flx m-0" do %>
        <i class="fas fa-history"></i>
        &nbsp;
        Past Events
      <% end %>

      <%= render "events_list", events: @events %>

    <% end %>
  </div>
  <div class="col-lg-3"></div>
</div>
