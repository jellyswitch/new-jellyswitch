
<% title "What's Happening?" %>

<div class="row mt-1 mb-0 p-0">
  <div class="col-lg-3"></div>
  <div class="col-lg-6 m-0 p-0">
    <%= list_wrapper do %>
      <%= list_item do %>
        <h4 class="display-4 text-center">What's Happening?</h4>
        <%= link_to new_event_path, class: "btn btn-block btn-primary" do %>
          <i class="far fa-calendar-alt"></i>
          &nbsp;
          Create an event
        <% end %>
      <% end %>

      <% @events.each do |event_hash| %>
        <%= list_item do %>
          <div class="row">
            <div class="col">
              <h5 class="mb-0"><%= human_time_from_now(event_hash.first) %></h5>
              <span class="text-secondary mt-0"><%= short_date(event_hash.first) %></span>
            </div>
          </div>
          <% event_hash.last.each do |event| %>
            <div class="row mt-2 mb-5">
              <div class="col">
                <%= render "event_item", event: event %>
              </div>
            </div>
          <% end %>
        <% end %>
      <% end %>
    <% end %>
  </div>
  <div class="col-lg-3"></div>
</div>
