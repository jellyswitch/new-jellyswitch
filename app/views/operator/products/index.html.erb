
<div class="row mt-3">
  <div class="col-sm-3"></div>
  <div class="col-sm">
    <div class="jumbotron bg-white pb-2 pt-2">
      <h4 class="display-4 text-center mt-4">Products</h4>
      <%= link_to "Add a new product", new_product_path, class: "btn btn-primary btn-sm" %>
      <table class="table">
        <tr>
          <th>Product</th>
          <th>Price</th>
          <th>Actions</th>
        </tr>
        <%- @products.each do |product| %>
          <tr>
            <td><%= link_to product.name, product_path(product) %></td>
            <td><%= number_to_currency(product.pretty_price) %></td>
            <td><%= render "actions", product: product %></td>
          </tr>
        <%- end %>
      </table>
    </div>
  </div>
  <div class="col-sm-3"></div>
</div>
