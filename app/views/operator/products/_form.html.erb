<%= form_for(product, remote: true) do |f| %>
  <%= render "shared/error_messages" , model: product %>

  <div class="form-group">
    <%= f.label :name %>
    <%= f.text_field :name, class: "form-control" %>
  </div>

  <div class="form-group">
    <%= f.label :price, "Price (in cents)" %>
    <%= f.number_field :price, class: "form-control" %>
  </div>

  <div class="form-group">
    <div class="form-check">
      <%= f.check_box :visible, class: "form-check-input" %>
      <%= f.label :visible, class: "form-check-label" %>
    </div>

    <div class="form-check">
      <%= f.check_box :available, class: "form-check-input" %>
      <%= f.label :available, class: "form-check-label" %>
    </div>
  </div>
  <br />
  <%= f.submit label, class: "form-control btn btn-primary" %>
<%- end %>
