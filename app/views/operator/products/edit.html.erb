<div class="row mt-3">
  <div class="col-sm-3"></div>
  <div class="col-sm">
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><%= link_to "Products", products_path %></li>
        <li class="breadcrumb-item"><%= link_to @product.name, products_path(@product) %></li>
        <li class="breadcrumb-item active" aria-current="page">Edit</li>
      </ol>
    </nav>
    <div class="jumbotron bg-white pb-2 pt-2">
      <h4 class="display-4 text-center mt-4">Edit Product</h4>
      <%= render "form", label: "Update", product: @product %>
      <div class="row mt-3">
        <div class="col-12">
          <%= link_to "Cancel", product_path(@product), class: "btn btn-block btn-warning" %>
        </div>
      </div>
    </div>
  </div>
  <div class="col-sm-3"></div>
</div>
