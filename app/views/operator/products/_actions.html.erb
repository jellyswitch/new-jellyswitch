<%= link_to "Edit this product", edit_product_path(product), class: "btn btn-info btn-sm" %>
<%- if product.available? %>
  <%= link_to "Archive", product_path(product), method: :delete, class: "btn btn-sm btn-danger" %>
<%- else %>
  <%= link_to "Unarchive", product_unarchive_path(product), method: :post, class: "btn btn-sm btn-warning" %>
<%- end %>
