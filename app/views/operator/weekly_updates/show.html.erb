<% title "Weekly Update" %>

<%= breadcrumb do %>
  <li class="breadcrumb-item"><%= link_to "Weekly Updates", weekly_updates_path %></li>
  <li class="breadcrumb-item active" aria-current="page">Weekly Update</li>
<% end %>

<div class="row mt-1 mb-0 p-0">
  <div class="col m-0 p-0">
    <%= list_wrapper do %>
      <%= list_item do %>
        <h5 class="display-5 text-center mb-3 mt-3"><%= pretty_dates(@weekly_update.week_start, @weekly_update.week_end) %></h5>

        <p>Hope you had a good weekend! Here's a summary of what happened in your spaces last week:</p>

        <ul class="list-group list-group-flush">   
          <li class="list-group-item">
            <div class="row mb-3 mt-3">
              <div class="col text-center">
                <i class="fas fa-chart-line display-4"></i>
              </div>
            </div>
            
            <div class="row">
              <p class="col">
                Your members paid <strong><%= @weekly_update.paid_invoices.count %> invoices</strong>, earning you <strong><%= number_to_currency(@weekly_update.revenue) %></strong> in revenue. There are <%= @weekly_update.unpaid_invoices.count %> unpaid invoices.
              </p>
            </div>
          

          
            <div class="row">
              <strong class="col-10">New paying members:</strong><span class="col"><%= @weekly_update.new_active_members %></span>
            </div>
            <div class="row">
              <strong class="col-10">New free members:</strong><span class="col"><%= @weekly_update.new_free_members %></span>
            </div>
            <div class="row">
              <strong class="col-10">Day Passes purchased:</strong><span class="col"><%= @weekly_update.day_passes %></span>
            </div>
            <div class="row">
              <strong class="col-10">Checkins:</strong><span class="col"><%= @weekly_update.checkins %></span>
            </div>
          </li>

          <li class="list-group-item">
            <div class="row mb-3 mt-3">
              <div class="col text-center">
                <i class="fas fa-users display-4"></i>
              </div>
            </div>

            <div class="row">
              <strong class="col-10">Paying members:</strong><span class="col"><%= @weekly_update.active_member_count %></span>
            </div>
            <div class="row">
              <strong class="col-10">Free / sponsored members:</strong><span class="col"><%= @weekly_update.free_member_count %></span>
            </div>
            <div class="row">
              <strong class="col-10">Members under office leases:</strong><span class="col"><%= @weekly_update.active_lease_member_count %></span>
            </div>
          </li>

          <li class="list-group-item">
            <div class="row mb-3 mt-3">
              <div class="col text-center">
                <i class="fas fa-clock display-4"></i>
              </div>
            </div>
            <div class="row">
              <p class="col">
                Your members made a total of <strong><%= @weekly_update.reservations %> room reservations</strong> last week, 
                <%= reservations_in_english(@weekly_update.rooms) %>.
              </p>
            </div>
          </li>

          <li class="list-group-item">
            <div class="row mb-3 mt-3">
              <div class="col text-center">
                <i class="fas fa-clipboard display-4"></i>
              </div>
            </div>
            <div class="row">
              <div class="col">
                You and your staff posted <strong><%= @weekly_update.management_notes.count %> management notes</strong> to the feed. <%= @weekly_update.questions.count %> were questions, <%= @weekly_update.unanswered_questions.count %> went unanswered.
              </div>
            </div>
          </li>
        </ul>
      <% end %>
    <% end %>
  </div>
</div>