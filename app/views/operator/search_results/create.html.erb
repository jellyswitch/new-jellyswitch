<%- title "Search Results" %>

<%= render "form" %>

<%= wide_card do %>
  <div class="row">
    <small class="col">
      <%= @results.count %> results in
      <%= @results.took %> ms
    </small>
  </div>
<%- end %>


<div class="row mt-3 mb-2">
  <div class="col-lg-3"></div>
  <div class="col-lg-6">

    <%- @results.each do |feed_item| %>
      <%= render "operator/feed_items/feed_item", feed_item: feed_item, comments: feed_item.feed_item_comments.count > 0 %>
    <%- end %>
  
  </div>

  <div class="col-lg-3"></div>
</div>