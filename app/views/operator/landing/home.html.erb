<% title current_location.name %>

<%= wide_card do %>
  <%= render "shared/building_access_card" %>
<% end %>

<% if current_tenant.announcements.count > 0 %>
  <%= wide_card do %>
    <%= render "shared/announcements_card" %>
  <% end %>
<% end %>

<% if current_location.rooms.visible.count > 0 %>
  <%= wide_card do %>
    <%= render "shared/reservations_card" %>
  <% end %>
<% end %>

<%= wide_card do %>
  <%= render "shared/send_feedback_card" %>
<% end %>

<%= wide_card do %>
  <%= render "shared/wifi" %>
<% end %>

<%= wide_card do %>
  <%= render "shared/map_card" %>
<% end %>

<% if current_location.has_contact_info? %>
  <%= wide_card do %>
    <%= render "shared/contact_card" %>
  <% end %>
<% end %>
