<div class="row">
  <div class="col-sm-1"></div>
  <div class="col">
    <div class="jumbotron mt-3 pt-4 bg-light">
      <div class="row">
        <div class="col">
          <h1 class="display-4 mt-1">Welcome to <%= current_tenant.name %>!</h1>
          <p class="lead mt-3">
            <%= render "snippet", operator: current_tenant %>
          </p>
        </div>
      </div>
      <div class="row mt-3">
        <div class="col">
          <%= image_tag google_map(center: current_tenant.building_address), class: "img-fluid" %>
        </div>
        <p class="col small">
          <%= current_tenant.name %> is located at <%= link_to current_tenant.building_address, "https://maps.google.com/?q=#{current_tenant.building_address}", target: "_blank" %>.
        </p>
      </div>
      <div class="row mt-3">
        <%= link_to "Sign Up to get started", signup_path, class: "btn btn-lg btn-primary m-1" %>
        <%= link_to "Sign in", login_path, class: "btn btn-lg btn-info m-1" %>
      </div>
    </div>
  </div>
  <div class="col-sm-1"></div>
</div>

<script>

</script>

