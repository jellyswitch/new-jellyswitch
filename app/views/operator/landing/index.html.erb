
<% if current_location %>
  <%= super_wide_card do %>
    <div class="row">
      <div class="col">
        <h1 class="display-4 mt-1">Welcome to <%= current_location.name %>!</h1>
        <p class="lead mt-3">
          <%= render "snippet", location: current_location %>
        </p>
      </div>
    </div>
    <div class="row mt-3">
      <div class="col">
        <%= image_tag google_map(center: current_location.building_address), class: "img-fluid" %>
      </div>
      <p class="col small">
        <%= current_location.name %> is located at <%= link_to current_location.building_address, "https://maps.google.com/?q=#{current_location.building_address}", target: "_blank" %>.
      </p>
    </div>
    <div class="row mt-3">
      <%= link_to "Sign Up to get started", signup_path, class: "btn btn-lg btn-primary m-1", data: { acc: 'signup' } %>
      <%= link_to "Sign in", login_path, class: "btn btn-lg btn-info m-1", data: { acc: 'signin' } %>
    </div>
  <% end %>
<% else %>
  <%= render Location.visible, label: "Take me to" %>
<% end %>



<% if current_location %>
  <%= super_wide_card do %>
    <%= render "shared/contact_card" %>
  <% end %>
<% end %>
