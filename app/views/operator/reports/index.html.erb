<% title "Data" %>

<%= super_wide_card do %>
  <h4 class="display-4 mb-1 text-center"><%= current_location ? "#{current_location.name} Data" : "Data" %></h4>
  <p class="text-center text-muted mb-4">
    Change to another location for its data
  </p>

  <%# ── Key Metrics ── %>
  <% breakdown = @report.active_member_breakdown %>
  <div class="row text-center mb-3">
    <div class="col-6 mb-3">
      <%= link_to active_members_reports_path, class: "text-decoration-none text-dark d-block h-100" do %>
        <div class="border rounded p-3 h-100 d-flex flex-column justify-content-center">
          <div class="h1 mb-0 font-weight-bold text-primary"><%= @report.active_member_count %></div>
          <div class="text-muted small mt-1">Active Members</div>
          <small class="text-muted" style="font-size: 0.7rem;">
            <%= breakdown[:subscribed] %> subscribed<% if breakdown[:out_of_band] > 0 %> · <%= breakdown[:out_of_band] %> out-of-band<% end %>
          </small>
        </div>
      <% end %>
    </div>

    <div class="col-6 mb-3">
      <%= link_to active_leases_reports_path, class: "text-decoration-none text-dark d-block h-100" do %>
        <div class="border rounded p-3 h-100 d-flex flex-column justify-content-center">
          <div class="h1 mb-0 font-weight-bold text-success"><%= @report.active_lease_count %></div>
          <div class="text-muted small mt-1">Active Leases</div>
        </div>
      <% end %>
    </div>

    <div class="col-6 mb-3">
      <%= link_to active_lease_members_reports_path, class: "text-decoration-none text-dark d-block h-100" do %>
        <div class="border rounded p-3 h-100 d-flex flex-column justify-content-center">
          <div class="h1 mb-0 font-weight-bold text-info"><%= @report.active_lease_member_count %></div>
          <div class="text-muted small mt-1">Lease Members</div>
        </div>
      <% end %>
    </div>

    <div class="col-6 mb-3">
      <div class="border rounded p-3 h-100 d-flex flex-column justify-content-center">
        <% if current_location %>
          <div class="mb-0 font-weight-bold text-warning" style="font-size: 1.4rem;"><%= number_to_currency(@report.this_month_revenue, precision: 0) %></div>
          <div class="text-muted small mt-1">Revenue This Month</div>
        <% else %>
          <div class="h2 mb-0 font-weight-bold text-muted">--</div>
          <div class="text-muted small mt-1">Revenue This Month</div>
        <% end %>
      </div>
    </div>
  </div>

  <%# ── Secondary Stats ── %>
  <div class="row text-center mb-2">
    <div class="col-6 mb-3">
      <%= link_to total_members_reports_path, class: "text-decoration-none text-dark d-block h-100" do %>
        <div class="border rounded p-3 h-100 d-flex flex-column justify-content-center">
          <div class="h3 mb-0 font-weight-bold"><%= @report.all_member_count %></div>
          <div class="text-muted small">Total Members</div>
        </div>
      <% end %>
    </div>

    <div class="col-6 mb-3">
      <%= link_to last_30_day_passes_reports_path, class: "text-decoration-none text-dark d-block h-100" do %>
        <div class="border rounded p-3 h-100 d-flex flex-column justify-content-center">
          <div class="h3 mb-0 font-weight-bold"><%= @report.last_30_day_pass_count %></div>
          <div class="text-muted small">Day Passes (30d)</div>
        </div>
      <% end %>
    </div>

    <div class="col-6 mb-3">
      <div class="border rounded p-3 h-100 d-flex flex-column justify-content-center">
        <div class="h3 mb-0 font-weight-bold"><%= @report.free_member_count %></div>
        <div class="text-muted small">Free Members</div>
      </div>
    </div>

    <div class="col-6 mb-3">
      <div class="border rounded p-3 h-100 d-flex flex-column justify-content-center">
        <div class="h3 mb-0 font-weight-bold"><%= @report.checkins_last_30_days_count %></div>
        <div class="text-muted small">Check-ins (30d)</div>
      </div>
    </div>
  </div>
<% end %>

<%# ── Membership Breakdown ── %>
<%= super_wide_card do %>
  <h5 class="text-center mb-3">Membership Breakdown</h5>
  <div class="row">
    <div class="col-md-8 mx-auto">
      <%= pie_chart @report.membership_breakdown_count,
            donut: true,
            legend: "bottom",
            colors: ["#4e79a7", "#f28e2b", "#e15759", "#76b7b2", "#59a14f", "#edc948", "#b07aa1", "#ff9da7"],
            height: "300px",
            library: { plugins: { legend: { labels: { boxWidth: 12, padding: 15 } } } } %>
    </div>
  </div>
  <div class="text-center mt-3">
    <%= link_to "View Details", membership_breakdown_reports_path, class: "btn btn-outline-primary btn-sm" %>
  </div>
<% end %>

<%# ── Revenue Trend ── %>
<% if policy(:report).revenue? && current_location %>
  <%= super_wide_card do %>
    <h5 class="text-center mb-3">Revenue — Last 12 Months</h5>
    <p class="text-center text-muted small mb-3">Based on paid invoices</p>
    <%= column_chart @report.revenue_by_month,
          prefix: "$",
          thousands: ",",
          colors: ["#4e79a7"],
          height: "300px",
          library: {
            scales: { y: { beginAtZero: true } },
            plugins: { legend: { display: false } }
          } %>
    <div class="text-center mt-3">
      <%= link_to "Detailed Revenue", revenue_reports_path, class: "btn btn-outline-primary btn-sm" %>
    </div>
  <% end %>
<% end %>

<%# ── Lifetime Value ── %>
<% if current_location %>
  <% ltv = @report.ltv_summary %>
  <%= super_wide_card do %>
    <h5 class="text-center mb-3">Customer Lifetime Value</h5>
    <p class="text-center text-muted small mb-3">All-time average and median revenue per customer by product</p>

    <table class="table table-sm text-center">
      <thead>
        <tr>
          <th class="text-left">Product</th>
          <th>Customers</th>
          <th>Total Revenue</th>
          <th>Avg LTV</th>
          <th>Median LTV</th>
        </tr>
      </thead>
      <tbody>
        <% [:day_passes, :memberships, :office_leases, :meeting_rooms].each do |key| %>
          <% r = ltv[key] %>
          <tr>
            <td class="text-left"><%= r.product %></td>
            <td><%= number_with_delimiter(r.customers) %></td>
            <td><%= number_to_currency(r.total_revenue, precision: 0) %></td>
            <td class="font-weight-bold"><%= number_to_currency(r.average, precision: 0) %></td>
            <td><%= number_to_currency(r.median, precision: 0) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>

    <div class="text-center mt-3">
      <%= link_to "Detailed LTV Analysis", ltv_reports_path, class: "btn btn-outline-primary btn-sm" %>
    </div>
  <% end %>
<% end %>

<%# ── Quick Links ── %>
<%= wide_card do %>
  <h5 class="text-center mb-3">Reports</h5>

  <div class="row">
    <div class="col-md-6">
      <div class="list-group list-group-flush">
        <%= link_to active_members_reports_path, class: "list-group-item list-group-item-action d-flex justify-content-between align-items-center" do %>
          Active Members
          <span class="badge badge-primary badge-pill"><%= @report.active_member_count %></span>
        <% end %>
        <%= link_to active_leases_reports_path, class: "list-group-item list-group-item-action d-flex justify-content-between align-items-center" do %>
          Active Leases
          <span class="badge badge-primary badge-pill"><%= @report.active_lease_count %></span>
        <% end %>
        <%= link_to active_lease_members_reports_path, class: "list-group-item list-group-item-action d-flex justify-content-between align-items-center" do %>
          Lease Members
          <span class="badge badge-primary badge-pill"><%= @report.active_lease_member_count %></span>
        <% end %>
        <%= link_to total_members_reports_path, class: "list-group-item list-group-item-action d-flex justify-content-between align-items-center" do %>
          Total Members
          <span class="badge badge-primary badge-pill"><%= @report.all_member_count %></span>
        <% end %>
      </div>
    </div>

    <div class="col-md-6">
      <div class="list-group list-group-flush">
        <%= link_to membership_breakdown_reports_path, class: "list-group-item list-group-item-action" do %>
          Membership Breakdown
        <% end %>
        <% if policy(:report).revenue? %>
          <%= link_to revenue_reports_path, class: "list-group-item list-group-item-action" do %>
            Revenue
          <% end %>
        <% end %>
        <%= link_to checkins_reports_path, class: "list-group-item list-group-item-action" do %>
          Check-ins
        <% end %>
        <%= link_to last_30_day_passes_reports_path, class: "list-group-item list-group-item-action d-flex justify-content-between align-items-center" do %>
          Day Passes (30 days)
          <span class="badge badge-primary badge-pill"><%= @report.last_30_day_pass_count %></span>
        <% end %>
      </div>
    </div>
  </div>

  <div class="row mt-3">
    <div class="col-md-6">
      <%= link_to member_csv_reports_path, class: "btn btn-outline-secondary btn-block btn-sm" do %>
        <i class="fas fa-download"></i> Email Member CSV
      <% end %>
    </div>
    <div class="col-md-6">
      <%= link_to weekly_updates_path, class: "btn btn-outline-secondary btn-block btn-sm" do %>
        <i class="fas fa-calendar-week"></i> Weekly Updates
      <% end %>
    </div>
  </div>
<% end %>

<%# ── Monetization ── %>
<% if current_location %>
  <%= wide_card do %>
    <h5 class="text-center mb-3">Monetization</h5>
    <%= link_to monetization_reports_path(location_id: current_location.id), class: "btn btn-primary btn-block" do %>
      View Monetization — <%= current_location.name %>
    <% end %>
  <% end %>
<% end %>
