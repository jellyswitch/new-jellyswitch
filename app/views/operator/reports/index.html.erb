<% title "Data" %>

<%= wide_card do %>
  <h4 class="display-4 mb-1 text-center">Data Reports<%= current_location ? " for #{current_location.name}" : "" %></h4>
  <p class="text-center mb-5">
    Change to another location for its data
  </p>

  <dl class="row">
    <dt class="col-lg-6">Weekly Updates</dt>
    <dd class="col"><%= link_to "View Weekly Updates", weekly_updates_path, class: "btn btn-primary btn-block" %></dd>
  </dl>

  <dl class="row">
    <dt class="col-lg-6"><%= @report.active_member_count %> active members</dt>
    <dd class="col"><%= link_to "View Data", active_members_reports_path, class: "btn btn-primary btn-block" %></dd>
  </dl>

  <dl class="row">
    <dt class="col-lg-6"><%= @report.active_lease_count %> active leases</dt>
    <dd class="col"><%= link_to "View Data", active_leases_reports_path, class: "btn btn-primary btn-block" %></dd>
  </dl>

  <dl class="row">
    <dt class="col-lg-6"><%= @report.active_lease_member_count %> members on active leases</dt>
    <dd class="col"><%= link_to "View Data", active_lease_members_reports_path, class: "btn btn-primary btn-block" %></dd>
  </dl>

  <dl class="row">
    <dt class="col-lg-6"><%= @report.last_30_day_pass_count %> day passes (last 30 days)</dt>
    <dd class="col"><%= link_to "View Data", last_30_day_passes_reports_path, class: "btn btn-primary btn-block" %></dd>
  </dl>

  <dl class="row">
    <dt class="col-lg-6"><%= @report.all_member_count %> total members</dt>
    <dd class="col"><%= link_to "View Data", total_members_reports_path, class: "btn btn-primary btn-block" %></dd>
  </dl>

  <dl class="row">
    <dt class="col-lg-6">Membership Breakdown</dt>
    <dd class="col"><%= link_to "View Data", membership_breakdown_reports_path, class: "btn btn-primary btn-block" %></dd>
  </dl>

<% if policy(:report).revenue? %>
  <dl class="row">
    <dt class="col-lg-6">Revenue</dt>
    <dd class="col"><%= link_to "View Data", revenue_reports_path, class: "btn btn-primary btn-block" %></dd>
  </dl>
<% end %>
  <dl class="row">
    <dt class="col-lg-6">Check-ins</dt>
    <dd class="col"><%= link_to "View Data", checkins_reports_path, class: "btn btn-primary btn-block" %></dd>
  </dl>

  <dl class="row">
    <dt class="col-lg-6">Download Member CSV</dt>
    <dd class="col"><%= link_to "Download", member_csv_reports_path, class: "btn btn-primary btn-block" %></dd>
  </dl>

 <% end %>

<%= wide_card do %>
  <h4 class="display-4 mb-5 text-center">Monetization</h4>

  <% if current_location %>
    <dl class="row">
      <dt class="col-lg-6"><%= current_location.name %></dt>
      <dd class="col"><%= link_to "View Data", monetization_reports_path(location_id: current_location.id), class: "btn btn-primary btn-block" %></dd>
    </dl>
  <% end %>
<% end %>