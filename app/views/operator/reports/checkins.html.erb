<% title "Check-ins" %>

<%= wide_card do %>
  <div class="mb-3">
    <%= link_to "&larr; Back to Dashboard".html_safe, reports_path, class: "btn btn-sm btn-outline-secondary" %>
  </div>

  <h4 class="display-4 text-center">Check-ins</h4>
  <p class="text-center text-muted">Last 90 days</p>

  <% @report.checkins_by_day.each do |report| %>
    <h5 class="mt-4 mb-3"><%= report.label %></h5>
    <%= column_chart report.data,
          colors: ["#4e79a7"],
          height: "300px",
          library: {
            scales: { y: { beginAtZero: true } },
            plugins: { legend: { display: false } }
          } %>
  <% end %>
<% end %>

<%= wide_card do %>
  <h4 class="display-4 text-center">Revenue from Check-ins</h4>
  <p class="text-center text-muted">Last 90 days</p>

  <% @report.checkin_revenue_by_day.each do |report| %>
    <h5 class="mt-4 mb-3"><%= report.label %></h5>
    <%= column_chart report.data,
          prefix: "$", thousands: ",",
          colors: ["#59a14f"],
          height: "300px",
          library: {
            scales: { y: { beginAtZero: true } },
            plugins: { legend: { display: false } }
          } %>
  <% end %>
<% end %>
