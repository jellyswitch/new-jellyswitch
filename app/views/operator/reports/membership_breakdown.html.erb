<% title "Membership Breakdown" %>

<%= wide_card do %>
  <div class="mb-3">
    <%= link_to "&larr; Back to Dashboard".html_safe, reports_path, class: "btn btn-sm btn-outline-secondary" %>
  </div>

  <h4 class="display-4 text-center">Membership Breakdown</h4>
  <div class="row">
    <div class="col-md-8 mx-auto">
      <%= pie_chart @report.membership_breakdown_count,
            donut: true,
            legend: "bottom",
            colors: ["#4e79a7", "#f28e2b", "#e15759", "#76b7b2", "#59a14f", "#edc948", "#b07aa1", "#ff9da7"],
            height: "300px",
            library: { plugins: { legend: { labels: { boxWidth: 12, padding: 15 } } } } %>
    </div>
  </div>
<% end %>

<% @report.membership_breakdown_plan_count.keys.each do |plan| %>
  <%= wide_card do %>
    <h5 class="text-center"><%= plan.pretty_name %></h5>
    <p class="text-center text-muted"><%= plan.subscriptions.active.count %> members</p>

    <table class="table table-sm">
      <% plan.subscriptions.active.each do |subscription| %>
        <tr>
          <td><%= link_to subscription.subscribable.name, user_path(subscription.subscribable) %></td>
        </tr>
      <% end %>
    </table>
  <% end %>
<% end %>
