<div class="list-group-item">
  <div class="float-left">
    <p class="lead">
      <%= link_to invoice.billable.name, path_for_billable(invoice) %>
    </p>
    <p>
      <span class="badge badge-dark"><%= invoice.payment_method %></span>
    </p>
    <% if invoice.paid? %>
      <span class="badge badge-success">paid</span>
    <% else %>
      <span class="badge badge-info"><%= invoice.status %></span>
    <% end %>
    <% if invoice.refunded? %>
      <span class="badge badge-info">refunded</span>
    <% end %>
  </div>
  <div class="float-right">
    <small>Created <%= invoice.pretty_date %></small>
    <% if invoice.due_date.present? %>
      <br />
      <small>Due <%= invoice.pretty_due_date %></small>
    <% end %>
    <br />
    <h4 class="text-success mt-1"><%= number_to_currency(invoice.amount_due.to_f / 100.0) %></h4>
    <%= link_to "Download PDF", invoice.pdf_url, class: "btn btn-sm btn-primary" %>

    <% if invoice.paid?  %>
      <div class="clearfix mb-1"></div>
      <%= button_to "Refund", invoice_refunds_path(invoice), class: "btn btn-sm btn-secondary" %>
    <% end %>

    <% if invoice.voidable?  %>
      <div class="clearfix mb-1"></div>
      <%= button_to "Void", invoice_refunds_path(invoice), class: "btn btn-sm btn-secondary" %>
    <% end %>

    <% if invoice.open? %>
      <div class="clearfix mb-1"></div>
      <%= link_to "Mark as paid", invoice_mark_paid_path(invoice), class: "btn btn-sm btn-success" %>

      <% if policy(invoice).charge? %>
        <div class="clearfix mb-1"></div>
        <%= link_to "Pay with card on file", invoice_charge_path(invoice), class: "btn btn-sm btn-success" %>
      <% end %>
    <% end %>
  </div>
</div>
