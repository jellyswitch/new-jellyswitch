
<div class="list-group-item">
  <p class="text-center">
    <strong><%= invoice.description %></strong>
  </p>
  <h4 class="text-success text-center mt-1"><%= number_to_currency(invoice.amount_due.to_f / 100.0) %></h4>
  <div class="row mt-3">
    <div class="col">
      <dl class="row">
        <dt class="col-6">Billable To</dt>
        <dd class="col"><%= link_to invoice.billable.name, path_for_billable(invoice) %></dd>
      
        <dt class="col-6">Invoiced on</dt>
        <dd class="col"><%= invoice.pretty_date %></dd>

        <dt class="col-6">Due on</dt>
        <dd class="col"><%= invoice.pretty_due_date %></dd>

        <dt class="col-6">Method</dt>
        <dd class="col">
          <span class="badge badge-dark"><%= invoice.payment_method %></span>
        </dd>

        <dt class="col-6">Status</dt>
        <dd class="col">
          <% if invoice.paid? %>
            <span class="badge badge-success">paid</span>
          <% else %>
            <span class="badge badge-info"><%= invoice.status %></span>
          <% end %>
        </dd>
      </dl>
    </div>
  </div>
  <div class="row">
    <div class="col">
      <%= link_to "Download PDF", invoice.pdf_url, class: "btn btn-block btn-primary" %>

      <% if invoice.paid?  %>
        <div class="clearfix mb-1"></div>
        <% if policy(:invoice).create? %>
          <%= button_to invoice_refunds_path(invoice), remote: true, class: "btn btn-block btn-secondary" do %>
            <span class="show-when-enabled">
              Refund
            </span>
            <span class="show-when-disabled">
              Refunding...
            </span>
          <% end %>
        <% end %>
      <% end %>

      <% if invoice.voidable?  %>
        <div class="clearfix mb-1"></div>
        <%= button_to invoice_refunds_path(invoice), class: "btn btn-block btn-secondary", remote: true do  %>
          <span class="show-when-enabled">
            Void
          </span>
          <span class="show-when-disabled">
            Voiding...
          </span>
        <% end %>
      <% end %>

      <% if invoice.open? %>
        <div class="clearfix mb-1"></div>
        <%= link_to invoice_mark_paid_path(invoice), class: "btn btn-block btn-success", remote: true do %>
          <span class="show-when-enabled">
            Mark as paid
          </span>
          <span class="show-when-disabled">
            Marking as paid...
          </span>
        <% end %>

        <% if policy(invoice).charge? %>
          <div class="clearfix mb-1"></div>
          <%= button_to invoice_charge_path(invoice), method: :get, class: "btn btn-block btn-success", remote: true do %>
            <span class="show-when-enabled">
              Pay with card on file
            </span>
            <span class="show-when-disabled">
              Charging customer...
            </span>
          <% end %>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
