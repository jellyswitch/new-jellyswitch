<%= form_for(@plan, remote: true) do |f| %>
  <%= render "shared/error_messages" , model: @plan %>

  <div class="form-group">
    <%= f.label :name %>
    <%= f.text_field :name, class: "form-control" %>
  </div>

  <% unless hide_types %>
    <div class="form-group">
      <%= f.label :plan_type %>
      <%= f.select :plan_type, Plan::PLAN_TYPES, class: "form-control" %>
    </div>
  <% end %>

  <div class="form-group">
    <%= f.label :interval %>
    <%= f.select :interval, Plan.options_for_interval, class: "form-control" %>
  </div>

  <div class="form-group">
    <%= f.label :amount_in_cents %>
    <%= f.number_field :amount_in_cents, class: "form-control" %>
  </div>

  <div class="form-group">
    <div class="form-check">
      <%= f.check_box :visible, class: "form-check-input" %>
      <%= f.label :visible, class: "form-check-label" %>
    </div>

    <div class="form-check">
      <%= f.check_box :available, class: "form-check-input" %>
      <%= f.label :available, class: "form-check-label" %>
    </div>
  </div>
  <br />
  <%= f.submit label, class: "form-control btn btn-primary" %>
<%- end %>
