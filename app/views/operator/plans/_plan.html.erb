<%= list_item do %>
  <div class="row">
    <div class="col">
      <h5><%= plan.name %></h5>
    </div>
  </div>
  
  <div class="row">
    <div class="col">
      <%= render "operator/plans/price", plan: plan %>
    </div>
  </div>

  <% plan.locations.each do |location| %>
    <%= render "operator/plans/location_check", location: location %>
  <% end %>


  <div class="row">
    <div class="col">
      <%= link_to 'View', plan, class: "btn btn-block btn-primary mt-3" %>
    </div>
  </div>

<% end %>
