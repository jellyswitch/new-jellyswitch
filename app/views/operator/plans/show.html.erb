<%- title @plan.name %>

<%= breadcrumb do %>
  <li class="breadcrumb-item"><%= link_to "Plans", plans_path %></li>
  <li class="breadcrumb-item active" aria-current="page"><%= @plan.name %></li>
<% end %>

<%= render(FullWidth) do %>
  <%= list_wrapper do %>
    
    <%= list_item do %>
  
      <h4 class="display-4 text-center"><%= @plan.name %></h4>

      <%= render "operator/plans/price", plan: @plan %>

      <% if @plan.visible? %>
        <div class="row">
          <div class="col">
            <i class="fas fa-check"></i>
            &nbsp;
            Visible to new members
          </div>
        </div>
      <% end %>

      <% if @plan.available? %>
        <div class="row">
          <div class="col">
            <i class="fas fa-check"></i>
            &nbsp;
            Available for admins to add
          </div>
        </div>
      <% end %>

      <% if @plan.always_allow_building_access? %>
        <div class="row">
          <div class="col">
            <i class="fas fa-check"></i>
            &nbsp;
            Includes 24/7 building access
          </div>
        </div>
      <% end %>

      <% if @plan.has_day_limit? %>
        <div class="row">
          <div class="col">
            <strong><%= @plan.day_limit %></strong> days included
          </div>
        </div>
      <% end %>

      <div class="mt-3"></div>
      <% if @plan.locations.count < 1 %>
        <div class="row">
          <div class="col">
            Not available at any locations.
          </div>
        </div>
      <% else %>
        <div class="row">
          <div class="col">
            Available at:
          </div>
        </div>
        <% @plan.locations.each do |location| %>
          <div class="row">
            <div class="col">
              <i class="fas fa-check"></i>
              &nbsp;
              <%= location.name %>
            </div>
          </div>
        <% end %>
      <% end %>

      <div class="row mt-3">
        <div class="col">
          <%- if @plan.available? %>
            <%= link_to "Edit", edit_plan_path(@plan), class: "btn btn-block btn-primary" %>
            <%= link_to "Archive", plan_path(@plan), method: :delete, remote: true, class: "btn btn-block btn-danger" %>
          <%- else %>
            <%= link_to "Unarchive", plan_unarchive_path(@plan), method: :post, remote: true, class: "btn btn-block btn-warning" %>
          <%- end %>
        </div>
      </div>

    <% end %>
  <% end %>
<% end %>

