<%- title @plan.name %>

<div class="row mt-3">
  <div class="col-sm-3"></div>
  <div class="col-sm">
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><%= link_to "Plans", plans_path %></li>
        <li class="breadcrumb-item active" aria-current="page"><%= @plan.name %></li>
      </ol>
    </nav>
    <div class="jumbotron bg-white pb-2 pt-2">
      
      <h4 class="display-4 text-center mt-4"><%= @plan.name %></h4>
      <%= render "actions", plan: @plan %>
      <dl class="row">
        <dt class="col-sm">Amount</dt>
        <dd class="col-sm"><%= dollar_amount(@plan.amount_in_cents) %></dd>
      </dl> 
      <dl class="row">
        <dt class="col-sm">Interval</dt>
        <dd class="col-sm"><%= @plan.interval %></dd>
      </dl>
      <dl class="row">
        <dt class="col-sm">Visible?</dt>
        <dd class="col-sm"><%= @plan.visible? %></dd>
      </dl> 
      <dl class="row">
        <dt class="col-sm">Available</dt>
        <dd class="col-sm"><%= @plan.available? %></dd>
      </dl>
      <dl class="row">
        <dt class="col-sm">Always has building access?</dt>
        <dd class="col-sm"><%= boolean_to_yesno(@plan.always_allow_building_access) %></dd>
      </dl>
      <dl class="row">
        <dt class="col-sm">Has a limit on days included?</dt>
        <dd class="col-sm"><%= boolean_to_yesno(@plan.has_day_limit?) %></dd>
      </dl>
      <dl class="row">
        <dt class="col-sm">Number of days included</dt>
        <dd class="col-sm"><%= @plan.day_limit%></dd>
      </dl>
    </div>
  </div>
  <div class="col-sm-3"></div>
</div>
