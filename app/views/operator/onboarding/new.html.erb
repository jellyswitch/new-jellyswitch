<% title "Onboarding" %>

<%= wide_card do %>
  <h4 class="display-4 text-cente">Let's get your space ready for customers!</h4>

  <ul class="list-group list-group-flush">
    <li class="list-group-item">
      <div class="row">
        <div class="col">
          <%= check_box_tag :foo, nil, current_tenant.plans.count > 0 %> <%= link_to "Set up membership plans", new_membership_plan_operator_onboarding_index_path %>
        </div>
      </div>
    </li>

    <li class="list-group-item">
      <div class="row">
        <div class="col">
          <%= check_box_tag :foo, nil, current_tenant.day_pass_types.count > 0 %> <%= link_to "Set up day passes", new_day_pass_type_operator_onboarding_index_path %>
        </div>
      </div>
    </li>

    <li class="list-group-item">
      <div class="row">
        <div class="col">
          <%= check_box_tag :foo, nil, current_location.rooms.count > 0 %> <%= link_to "Add reservable conference and/or phone rooms", new_room_operator_onboarding_index_path %>
        </div>
      </div>
    </li>

    <li class="list-group-item">
      <div class="row">
        <div class="col">
          <%= check_box_tag :foo, nil, current_location.doors.count > 0 %> Set up building access
        </div>
      </div>
    </li>

    <li class="list-group-item">
      <div class="row">
        <div class="col">
          <%= check_box_tag :foo, nil, current_tenant.users.admins.count > 1 %> Invite your staff
        </div>
      </div>
    </li>

    <li class="list-group-item">
      <div class="row">
        <div class="col">
          <%= check_box_tag :foo, nil, current_tenant.users.members.count > 0 %> <%= link_to "Import your member information", add_members_operator_onboarding_index_path %>
        </div>
      </div>
    </li>
  </ul>
<% end %>