<dl class="mt-3">
  <hr />
  <i>Properties</i>
  <hr />

  <dt>Status</dt>
  <dd><%= lead.status %></dd>

  <dt>Source</dt>
  <dd>
    <% if lead.source.present? %>
      <%= lead.source %>
    <% else %>
      <i>None</i>
    <% end %>
  </dd>

  <hr />
  <i>Computed Properties</i>
  <hr />

  <dt>Became a lead</dt>
  <dd>
    <% if lead.ahoy_visit.present? %>
      <%= short_date(lead.ahoy_visit.started_at) %>
    <% elsif lead.user.present? %>
      <%= short_date(lead.ahoy_visit.created_at) %>
    <% else %>
      <%= short_date(lead.created_at) %>
    <% end %>
  </dd>

  <dt>Email</dt>
  <dd><%= link_to lead.user.email, user_path(lead.user) %>


  <dt>Referrer</dt>
  <dd>
    <% if lead.ahoy_visit.present? && lead.ahoy_visit.referrer.present? %>
      <%= lead.ahoy_visit.referrer %>
    <% else %>
      <i>None</i>
    <% end %>
  </dd>

  <dt>Landing page</dt>
  <dd>
    <% if lead.ahoy_visit.present? && lead.ahoy_visit.landing_page.present? %>
      <%= lead.ahoy_visit.landing_page %>
    <% else %>
      <i>None</i>
    <% end %>
  </dd>
</dl>