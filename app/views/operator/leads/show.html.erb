<% title "Lead" %>

<%= breadcrumb do %>
  <%= breadcrumb_item label: "Leads", path: leads_path %>
  <%= breadcrumb_item label: @lead.user.name %>
<% end %>

<%= render Layout::FullWidth do %>
  <%= list_item do %>
    <p class="text-center"><%= @lead.user.name %></p>

    <div class="d-flex justify-content-center align-items-center mt-2">
      <%= image_tag @lead.gravatar, class: "img-fluid rounded-circle" %>
    </div>

    <ul class="nav nav-tabs nav-fill mt-4" id="lead-tab" role="tablist">
      <li class="nav-item">
        <a class="nav-link active" id="about-tab" data-toggle="tab" href="#about" role="tab" aria-controls="about" aria-selected="true">About</a>
      </li>

      <li class="nav-item">
        <a class="nav-link" id="notes-tab" data-toggle="tab" href="#notes" role="tab" aria-controls="notes" aria-selected="true">Notes</a>
      </li>
    </ul>
  

    <div class="tab-content" id="leadTabContent">
      <div class="tab-pane fade show active" id="about" role="tabpanel" aria-labelledby="about-tab">
        
          <dl class="mt-3">
            <dt>Became a lead</dt>
            <dd>
              <% if @lead.ahoy_visit.present? %>
                <%= short_date(@lead.ahoy_visit.started_at) %>
              <% elsif @lead.user.present? %>
                <%= short_date(@lead.ahoy_visit.created_at) %>
              <% else %>
                <%= short_date(@lead.created_at) %>
              <% end %>
            </dd>

            <dt>Email</dt>
            <dd><%= link_to @lead.user.email, user_path(@lead.user) %>

            <dt>Status</dt>
            <dd><%= @lead.status %></dd>

            <dt>Referrer</dt>
            <dd>
              <% if @lead.ahoy_visit.referrer.present? %>
                <%= @lead.ahoy_visit.referrer %>
              <% else %>
                <i>None</i>
              <% end %>
            </dd>

            <dt>Landing page</dt>
            <dd>
              <%= @lead.ahoy_visit.landing_page %>
            </dd>
          </dl>
        
      </div>

      <div class="tab-pane fade show" id="notes" role="tabpanel" aria-labelledby="notes-tab">
        <% @lead.lead_notes.each do |lead_note| %>
          <%= lead_note.content %>
          <hr />
        <% end %>

        <%= form_with(model: @lead.lead_notes.new, url: lead_notes_path(lead_id: @lead.id), method: :post, remote: true) do |f| %>
          <%= f.rich_text_area :content, placeholder: "Say something..." %>

          <%= f.hidden_field :user_id, value: current_user.id %>
          <%= f.hidden_field :lead_id, value: @lead.id %>

          <%= f.submit "Post a note", class: "btn btn-block btn-primary" %>
        <% end %>
      </div>
    <% end %>
  </div>
<% end %>