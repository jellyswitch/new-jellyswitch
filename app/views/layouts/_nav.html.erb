<% if !ios_request? %>

  <nav class="navbar navbar-expand-lg navbar-light bg-light">
    <a class="navbar-brand" href="<%= home_path %>" data-turbolinks-action="restore">
      <%= image_tag current_tenant.logo_image, width: 30, height: 30 if current_tenant.logo_image.attached? %>
      <%= current_tenant.name %>
    </a>
    <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarSupportedContent">
      <ul class="navbar-nav mr-auto">
        <% if logged_in? %>
          <li class="nav-item">
            <%= link_to "Home", home_path, class: "nav-link", data: { "turbolinks-action" => "restore" } %>
          </li>
          <li class="nav-item">
            <%= link_to "Reserve a room", rooms_path, class: "nav-link", data: { "turbolinks-action" => "restore" } %>
          </li>
          <li class="nav-item">
            <%= link_to "Building Access", keys_doors_path, class: "nav-link", data: { "turbolinks-action" => "restore" } %>
          </li>
          <li class="nav-item">
            <%= link_to "Office Spaces", offices_path, class: "nav-link", data: { "turbolinks-action" => "restore" } %>
          </li>
        <% else %>
          <li class="nav-item">
            <%= link_to "Sign Up", signup_path, class: "nav-link" %>
          </li>
          <li class="nav-item">
            <%= link_to "Sign In", login_path, class: "nav-link" %>
          </li>
        <% end %>
      </ul>

      <%= render "layouts/user_account_nav" %>
    </div>
  </nav>

<% end %>
