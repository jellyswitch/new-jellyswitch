<ul class="navbar-nav ml-auto">
  <li class="nav-item dropdown data-turbolinks-permanent">
    <a class="nav-link dropdown-toggle" href="#" id="accountDropdownLink" role="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
      <%= current_user.name %>
    </a>
    <div class="dropdown-menu dropdown-menu-right" aria-labelledby="accountDropdownLink">
      <%- if admin? %>
        <%= link_to "#{current_tenant.name} Settings", operator_path(current_tenant, subdomain: current_tenant.subdomain), class: "dropdown-item" %>
        <div class="dropdown-divider"></div>
      <%- end %>
      <%= link_to "My Account", user_path(current_user), class: "dropdown-item" %>
      <%= link_to "My Membership", user_memberships_path(current_user), class: "dropdown-item" %>
      <%= link_to "My Day Passes", user_day_passes_path(current_user), class: "dropdown-item" %>
      <%= link_to "My Reservations", user_reservations_path(current_user), class: "dropdown-item" %>
      <%= link_to "My Invoices", user_invoices_path(current_user), class: "dropdown-item" %>
      <%= link_to "Change Password", user_change_password_path(current_user), class: "dropdown-item" %>
      <%= link_to "Log out", logout_path, method: :delete, remote: true, class: "dropdown-item" %>
    </div>
  </li>
</ul>
