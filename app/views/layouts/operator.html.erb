<!DOCTYPE html>
<html lang="en">
  <head>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="icon" href="<%= favicon(current_tenant) %>">
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, height=device-height, initial-scale=1, shrink-to-fit=no">
    <meta name="turbolinks-cache-control" content="no-cache">
    <%= stylesheet_link_tag    'application', media: 'all', 'data-turbolinks-track': 'reload' %>
    <%= javascript_include_tag 'application', 'data-turbolinks-track': 'reload' %>
    <%- if @include_stripe %>
      <script src="https://js.stripe.com/v3/" data-turbolinks-track=reload></script>
      <script type="text/javascript">
        window.stripe_key = "<%= Rails.configuration.stripe[:publishable_key] %>";
      </script>
    <%- end %>
    <title><%= current_tenant.name %></title>
  </head>

  <%- if @background_image && @background_image.attached? %>
    <body style="background-image: url(<%= url_for(@background_image) %>); background-repeat: no-repeat; background-size: cover;">
  <%- else %>
    <body>
  <%- end %>
    <%- if logged_in? %>
      <%- if admin? %>
      <%= render "layouts/admin_nav" %>
      <%- else %>
        <%= render "layouts/nav" %>
      <%- end %>
    <%- else %>
      <%= render "layouts/logged_out_nav" %>
    <%- end %>
    <div class="container-fluid" style="min-height: 100vh;">
      <%= render "layouts/flash" %>
      <%= yield %>
    </div>
  </body>
</html>
