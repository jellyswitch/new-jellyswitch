<%- if current_tenant.present? && current_tenant.has_stripe_info? %>
<script type="text/javascript">
    window.stripe_key = "<%= Rails.configuration.stripe[:publishable_key] %>";
  </script>
<%- else %>
  <script type="text/javascript">
    window.stripe_key = "<%= Rails.configuration.stripe[:test_publishable_key] %>";
  </script>
<%- end %>