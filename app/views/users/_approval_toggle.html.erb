
<%- if user.approved? %>
  <%= form_for(user, url: user_unapprove_path(user), method: :post, html: {class: "form-inline d-inline"}) do |f| %>
    <%= f.hidden_field :approved, value: false %>
    <%= f.submit "Unapprove", class: "btn btn-sm btn-danger" %>
  <%- end %>
<%- else %>
  <%= form_for(user, url: user_approve_path(user), method: :post, html: {class: "form-inline d-inline"}) do |f| %>
    <%= f.hidden_field :approved, value: true %>
    <%= f.submit "Approve", class: "btn btn-sm btn-info" %>
  <%- end %>
<%- end %>

  