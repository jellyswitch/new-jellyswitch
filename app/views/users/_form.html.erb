<%= form_for(@user, remote: true) do |f| %>
  <%= render "shared/error_messages" , model: @user %>
  <div class="form-group row">
    <%= f.label :name, class: "col-sm-4 text-right mt-2" %>
    <%= f.text_field :name, placeholder: "Name", class: "form-control col" %>
  </div>
  <div class="form-group row">
    <%= f.label :email, class: "col-sm-4 text-right mt-2" %>
    <%= f.email_field :email, placeholder: "Email", class: "form-control col" %>
  </div>
  <div class="form-group row">
    <%= f.label :password, class: "col-sm-4 text-right mt-2" %>
    <%= f.password_field :password, placeholder: "Password", class: "form-control col" %>
  </div>
  <div class="form-group row">
    <%= f.label :password_confirmation, "Confirm password", class: "col-sm-4 text-right mt-2" %>
    <%= f.password_field :password_confirmation, placeholder: "Password confirmation", class: "form-control col" %>
  </div>
  <div class="form-group row">
    <div class="col-sm-4"></div>
    <%= f.submit label, class: "form-control btn btn-primary col" %>
  </div>
<%- end %>
