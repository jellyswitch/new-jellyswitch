<div class="row mt-3 mb-3">
  <div class="col-sm-3"></div>
  <div class="card col-sm bg-light p-3">
    <div class="card-body">
      <h1>My Day Passes <span><%= link_to "Buy a day pass", new_day_pass_path, class: "btn btn-sm btn-primary" %></span></h1>
      <table class="table table-sm">
        <tr>
          <th>Day Passes</th>
          <td></td>
        </tr>
        <%- @user.day_passes.each do |day_pass| %>
          <tr>
            <td></td>
            <td>
              <%= link_to day_pass.pretty_day, day_pass_path(day_pass) %>
            </td>
          </tr>
        <%- end %>
      </table>
    </div>
  </div>
  <div class="col-sm-3"></div>
</div>
